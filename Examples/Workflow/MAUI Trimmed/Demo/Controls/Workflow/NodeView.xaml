<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Demo.Controls"
             xmlns:behaviors="clr-namespace:VeloxDev.WorkflowSystem.AttachedBehaviors;assembly=VeloxDev.MAUI"
             x:Class="Demo.Controls.NodeView"
             behaviors:WorkflowSlotLayoutBehavior.IsEnabled="True"
             behaviors:WorkflowSlotLayoutBehavior.SlotNames="PART_InputSlot"
             behaviors:WorkflowSlotLayoutBehavior.SlotEnumeratorNames="PART_OutputSlots"
             behaviors:WorkflowSlotLayoutBehavior.CoordinateHostName="PART_Canvas">
    <Grid RowDefinitions="48,*">
        <Border Grid.RowSpan="2"
                Stroke="#D6A0FF"
                StrokeThickness="1.5"
                StrokeShape="RoundRectangle 6"
                BackgroundColor="#2A1E35" />

        <Grid Grid.RowSpan="2" ZIndex="6" InputTransparent="True" CascadeInputTransparent="False">
            <controls:SlotView x:Name="PART_InputSlot"
                               WidthRequest="20"
                               HeightRequest="20"
                               HorizontalOptions="Start"
                               VerticalOptions="Center"
                               Margin="-10,0,0,0"
                               BindingContext="{Binding InputSlot}"
                               SlotState="{Binding State}" />
        </Grid>

        <Border Grid.Row="0"
                BackgroundColor="#3A2550"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 4,4,0,0"
                behaviors:WorkflowNodeDragBehavior.CoordinateHostName="PART_Canvas"
                behaviors:WorkflowNodeDragBehavior.IsEnabled="True">
            <Label Text="{Binding Name}"
                   TextColor="White"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center" />
        </Border>

        <Border Grid.Row="1"
                BackgroundColor="#2A1E35"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,4,4">
            <VerticalStackLayout x:Name="PART_OutputSlots"
                                 Margin="14"
                                 Spacing="6"
                                 VerticalOptions="Center"
                                 BindableLayout.ItemsSource="{Binding OutputSlots.Items}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{Binding Name}"
                                   TextColor="#D6A0FF"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="End"
                                   VerticalTextAlignment="Center"
                                   Margin="0,0,10,0" />
                            <controls:SlotView Grid.Column="1"
                                               WidthRequest="16"
                                               HeightRequest="16"
                                               Margin="0,0,-8,0"
                                               BindingContext="{Binding Slot}"
                                               SlotState="{Binding Slot.State}" />
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
