<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Demo.Views.TreeView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Demo.Views"
    xmlns:behaviors="using:VeloxDev.WorkflowSystem.AttachedBehaviors"
    xmlns:vm="using:Demo.ViewModels"
    xmlns:csharp="using:VeloxDev.WorkflowSystem.CSharp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    behaviors:WorkflowSurfaceBehavior.IsEnabled="True"
    behaviors:WorkflowSurfaceBehavior.ScrollViewerName="PART_ScrollViewer"
    behaviors:WorkflowSurfaceBehavior.CanvasName="PART_Canvas"
    behaviors:WorkflowSurfaceBehavior.GridDecoratorName="PART_GridDecorator"
    behaviors:WorkflowSurfaceBehavior.PointerPressSourceName="PART_SurfaceBorder"
    mc:Ignorable="d">

    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <DataTemplate x:Key="NodeTemplate">
            <local:NodeView Width="{Binding Size.Width}"
                            Height="{Binding Size.Height}"
                            Canvas.Left="{Binding Anchor.Horizontal}"
                            Canvas.Top="{Binding Anchor.Vertical}"
                            Canvas.ZIndex="{Binding Anchor.Layer}"
                            IsEnabled="{Binding IsEnabled}"/>
        </DataTemplate>
        <DataTemplate x:Key="ControllerTemplate">
            <local:ControllerView Width="{Binding Size.Width}"
                                  Height="{Binding Size.Height}"
                                  Canvas.Left="{Binding Anchor.Horizontal}"
                                  Canvas.Top="{Binding Anchor.Vertical}"
                                  Canvas.ZIndex="{Binding Anchor.Layer}"
                                  IsEnabled="{Binding IsEnabled}"/>
        </DataTemplate>
        <DataTemplate x:Key="BoolSelectorTemplate">
            <local:BoolSelectorNodeView Width="{Binding Size.Width}"
                                        Height="{Binding Size.Height}"
                                        Canvas.Left="{Binding Anchor.Horizontal}"
                                        Canvas.Top="{Binding Anchor.Vertical}"
                                        Canvas.ZIndex="{Binding Anchor.Layer}"
                                        IsEnabled="{Binding IsEnabled}"/>
        </DataTemplate>
        <DataTemplate x:Key="EnumSelectorTemplate">
            <local:EnumSelectorNodeView Width="{Binding Size.Width}"
                                        Height="{Binding Size.Height}"
                                        Canvas.Left="{Binding Anchor.Horizontal}"
                                        Canvas.Top="{Binding Anchor.Vertical}"
                                        Canvas.ZIndex="{Binding Anchor.Layer}"
                                        IsEnabled="{Binding IsEnabled}"/>
        </DataTemplate>
        <DataTemplate x:Key="CSharpObjectTemplate">
            <local:CSharpObjectView Width="{Binding Size.Width}"
                                    Height="{Binding Size.Height}"
                                    Canvas.Left="{Binding Anchor.Horizontal}"
                                    Canvas.Top="{Binding Anchor.Vertical}"
                                    Canvas.ZIndex="{Binding Anchor.Layer}"
                                    IsEnabled="{Binding IsEnabled}"/>
        </DataTemplate>
        <DataTemplate x:Key="LinkTemplate">
            <local:PolylineCurveView StartLeft="{Binding Sender.Anchor.Horizontal}"
                                     StartTop="{Binding Sender.Anchor.Vertical}"
                                     EndLeft="{Binding Receiver.Anchor.Horizontal}"
                                     EndTop="{Binding Receiver.Anchor.Vertical}"
                                     CanRender="{Binding IsVisible}"
                                     LineColor="White"
                                     Width="{Binding ElementName=PART_Canvas, Path=ActualWidth}"
                                     Height="{Binding ElementName=PART_Canvas, Path=ActualHeight}"
                                     Canvas.ZIndex="-1" />
        </DataTemplate>
        <local:CustomTemplateSelector x:Key="NodeSelector"
                                      ControllerTemplate="{StaticResource ControllerTemplate}"
                                      NodeTemplate="{StaticResource NodeTemplate}"
                                      BoolSelectorTemplate="{StaticResource BoolSelectorTemplate}"
                                      EnumSelectorTemplate="{StaticResource EnumSelectorTemplate}"
                                      CSharpObjectTemplate="{StaticResource CSharpObjectTemplate}"
                                      LinkTemplate="{StaticResource LinkTemplate}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="8*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="2">
            <Border x:Name="PART_SurfaceBorder"
                    Margin="0,20,20,20"
                    Background="#0B1120"
                    BorderBrush="White"
                    BorderThickness="1"
                    CornerRadius="3">
                <local:WorkflowGridDecorator x:Name="PART_GridDecorator">
                    <ScrollViewer x:Name="PART_ScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  ZoomMode="Disabled">
                        <Canvas x:Name="PART_Canvas"
                                Width="{Binding Layout.ActualSize.Width}"
                                Height="{Binding Layout.ActualSize.Height}"
                                Background="Transparent"
                                behaviors:ViewPool.ItemsSource="{Binding Helper.VisibleItems}"
                                behaviors:ViewPool.TemplateSelector="{StaticResource NodeSelector}">

                            <Grid Canvas.ZIndex="-1"
                                  DataContext="{Binding VirtualLink}">
                                <local:PolylineCurveView StartLeft="{Binding Sender.Anchor.Horizontal}"
                                                         StartTop="{Binding Sender.Anchor.Vertical}"
                                                         EndLeft="{Binding Receiver.Anchor.Horizontal}"
                                                         EndTop="{Binding Receiver.Anchor.Vertical}"
                                                         CanRender="{Binding IsVisible}"
                                                         IsVirtual="True"
                                                         LineColor="White"
                                                         Width="{Binding ElementName=PART_Canvas, Path=ActualWidth}"
                                                         Height="{Binding ElementName=PART_Canvas, Path=ActualHeight}" />
                            </Grid>
                        </Canvas>
                    </ScrollViewer>
                </local:WorkflowGridDecorator>
            </Border>
            <behaviors:WorkflowMinimapOverlay HorizontalAlignment="Right"
                                              VerticalAlignment="Top"
                                              Margin="0,56,45,0"
                                              ScrollViewerName="PART_ScrollViewer"
                                              WorkflowTree="{Binding}"
                                              ScrollOffsetX="{Binding ScrollOffsetX, ElementName=PART_GridDecorator}"
                                              ScrollOffsetY="{Binding ScrollOffsetY, ElementName=PART_GridDecorator}"
                                              ContentOffsetX="{Binding ContentOffsetX, ElementName=PART_GridDecorator}"
                                              ContentOffsetY="{Binding ContentOffsetY, ElementName=PART_GridDecorator}"
                                              ViewportWidth="{Binding ActualWidth, ElementName=PART_SurfaceBorder}"
                                              ViewportHeight="{Binding ActualHeight, ElementName=PART_SurfaceBorder}"/>
        </Grid>

        <Grid Grid.Column="0" Margin="20,20,0,20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8">
                    <Button Content="Undo" Width="100" Height="50" Command="{Binding UndoCommand}" />
                    <Button Content="Redo" Width="100" Height="50" Command="{Binding RedoCommand}" />
                    <Button Content="Save" Width="100" Height="50" Click="SaveWorkflow" />
                    <Button Content="Select" Width="100" Height="50" Click="SelectWorkflow" />
                    <Button Content="Load Workflow Demo" Width="140" Height="50" Click="LoadNetworkDemo" />
                    <Button Content="Add C# Script Chain" Width="160" Height="50" Click="AddCSharpObject" />
                    <Button Content="Run C# Script" Width="160" Height="50" Click="RunCSharpPipeline" />

                    <TextBlock Margin="0,12,0,0" Text="节点总数：" Foreground="White" />
                    <TextBlock Text="{Binding Nodes.Count}" Foreground="White" />
                    <TextBlock Margin="0,8,0,0" Text="可见组件数：( Node / Link )" Foreground="White" />
                    <TextBlock Text="{Binding Helper.VisibleItems.Count}" Foreground="White" />

                    <!-- Agent 对话 -->
                    <Border Margin="0,12,0,0"
                            Padding="10"
                            Background="#202020"
                            BorderBrush="#4C4C4C"
                            BorderThickness="1"
                            CornerRadius="4">
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Agent 对话" Foreground="#7EC8FF" FontWeight="Bold" VerticalAlignment="Center" />
                                <ToggleSwitch Grid.Column="1"
                                              IsOn="{Binding UseStreamingAgentResponse, Mode=TwoWay}"
                                              OnContent="流式"
                                              OffContent="普通"
                                              FontSize="11"
                                              Margin="0,-6,0,-6" />
                            </Grid>
                            <ListView MaxHeight="300" x:Name="AgentLogScroller"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ItemsSource="{Binding AgentLog}"
                                      Background="Transparent" BorderThickness="0"
                                      SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#D8D8D8" TextWrapping="WrapWholeWords" Margin="0,2" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox x:Name="AgentInput"
                                         Grid.Column="0"
                                         PlaceholderText="输入消息..."
                                         Background="#2D2D2D"
                                         Foreground="White"
                                         KeyDown="OnAgentInputKeyDown" />
                                <Button Grid.Column="1"
                                        Content="发送"
                                        Margin="4,0,0,0"
                                        Click="OnSendToAgent" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 执行记录 -->
                    <Border Margin="0,12,0,0"
                            Padding="10"
                            Background="#202020"
                            BorderBrush="#4C4C4C"
                            BorderThickness="1"
                            CornerRadius="4">
                        <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto" x:Name="ExecutionLogScroller">
                            <StackPanel Spacing="6">
                                <TextBlock Text="实际执行顺序" Foreground="#7EC8FF" FontWeight="Bold" />
                                <TextBlock Foreground="#BDBDBD">
                                    <Run Text="已记录: " />
                                    <Run Text="{Binding ExecutionLog.Count}" />
                                </TextBlock>
                                <ListView ItemsSource="{Binding ExecutionLog}"
                                          Background="Transparent" BorderThickness="0"
                                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                          SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#D8D8D8" TextWrapping="WrapWholeWords" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Column="1" Width="5" Background="Gray" />
    </Grid>
</UserControl>
