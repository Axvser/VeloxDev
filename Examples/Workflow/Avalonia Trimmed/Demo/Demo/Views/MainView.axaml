<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:workflowVm="using:Demo.ViewModels.Workflow"
             xmlns:local="using:Demo"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Demo.Views.MainView"
             x:DataType="workflowVm:TreeViewModel">
  <Design.DataContext>
    <workflowVm:TreeViewModel />
  </Design.DataContext>

  <local:TreeView Width="{Binding $parent[Window].Bounds.Width}"
                  Height="{Binding $parent[Window].Bounds.Height}"
                  Background="#1e1e1e"/>
  
</UserControl>
