@page "/"
@page "/workflow"
@rendermode RenderMode.InteractiveServer
@using System.Collections.Specialized
@using System.ComponentModel
@implements IDisposable

<PageTitle>VeloxDev Workflow — Blazor Demo</PageTitle>

<div class="wf-app">
    <!-- Sidebar -->
    <aside class="wf-sidebar">
        <button class="sb-btn" title="Undo" @onclick="Undo" disabled="@(_session?.Tree?.UndoCommand?.CanExecute(null) != true)">
            ↩ Undo
        </button>
        <button class="sb-btn" title="Redo" @onclick="Redo" disabled="@(_session?.Tree?.RedoCommand?.CanExecute(null) != true)">
            ↪ Redo
        </button>
        <button class="sb-btn" title="Save workflow as JSON" @onclick="SaveWorkflow">
            💾 Save
        </button>
        <button class="sb-btn" title="Load workflow from JSON" @onclick="LoadWorkflow">
            📂 Load
        </button>
        <button class="sb-btn" title="Load Performance Test (1000 nodes)" @onclick="LoadPerformanceTest">
            🚀 Perf Test
        </button>

        <div class="sb-divider"></div>

        <div class="sb-info">
            <span>节点总数: <strong>@(_session?.Tree?.Nodes.Count ?? 0)</strong></span>
            <span>连接数: <strong>@(_session?.Tree?.Links.Count ?? 0)</strong></span>
        </div>

        <div class="sb-divider"></div>

        <!-- Agent Chat Panel -->
        <div class="sb-panel">
            <div class="sb-panel-header">
                <span>Agent 对话</span>
                <label class="sb-toggle">
                    <input type="checkbox" checked="@_useStreaming" @onchange="OnStreamingToggle" />
                    流式
                </label>
            </div>
            <div class="sb-agent-log" @ref="_agentLogRef">
                @if (_session?.Tree?.AgentLog is { } log)
                {
                    @foreach (var entry in log)
                    {
                        <div class="sb-log-entry">@entry</div>
                    }
                }
            </div>
            <div class="sb-agent-input-row">
                <input class="sb-agent-input" type="text" @bind="_agentMessage"
                       @onkeydown="OnAgentKeyDown" placeholder="输入消息..." />
                <button class="sb-agent-send" @onclick="SendToAgent" disabled="@string.IsNullOrWhiteSpace(_agentMessage)">
                    发送
                </button>
            </div>
        </div>

        <div class="sb-divider"></div>

        <!-- Execution Log Panel -->
        <div class="sb-panel">
            <div class="sb-panel-header">
                <span>实际执行顺序</span>
            </div>
            <div class="sb-exec-log" @ref="_execLogRef">
                @if (_session?.Tree?.ExecutionLog is { } execLog)
                {
                    <div class="sb-log-entry">已记录: @execLog.Count</div>
                    @foreach (var entry in execLog)
                    {
                        <div class="sb-log-entry">@entry</div>
                    }
                }
            </div>
        </div>
    </aside>

    <!-- Main Canvas Area -->
    <main class="wf-main">
        <div class="wf-toolbar">
            <button class="tb-btn tb-run" @onclick="RunWorkflow" disabled="@(_session?.Controller?.IsActive == true)">
                ▶ Run Flow
            </button>
            <button class="tb-btn tb-close" @onclick="StopWorkflow" disabled="@(_session?.Controller?.IsActive != true)">
                ■ Close Tree
            </button>
            <button class="tb-btn tb-reset" @onclick="ResetDemo">
                ↩ Reset
            </button>
            <span class="tb-status">@(_session?.Controller?.IsActive == true ? "● Running" : "○ Idle")</span>
            <span class="tb-layout">Layout: @_canvasLayoutSize</span>
        </div>

        <div class="wf-canvas-wrapper" @ref="_canvasScrollRef">
            <WorkflowGridDecorator RulerThickness="28" GridSpacing="40"
                                   Background="#0B1120"
                                   MinorColor="#2A2D2E"
                                   MajorColor="#3A3D40"
                                   AxisColor="#4D4D4D"
                                   RulerBackground="#252526"
                                   TickColor="#555555"
                                   LabelColor="#888888"
                                   DividerColor="#3A3D40">
                <div class="wf-canvas" style="width:@_canvasWidth;height:@_canvasHeight;background-image:repeating-linear-gradient(to right, transparent calc(var(--gs,40px) - 1px), var(--gc,#2A2D2E) calc(var(--gs,40px) - 1px), var(--gc,#2A2D2E) var(--gs,40px)),repeating-linear-gradient(to bottom, transparent calc(var(--gs,40px) - 1px), var(--gc,#2A2D2E) calc(var(--gs,40px) - 1px), var(--gc,#2A2D2E) var(--gs,40px));--gs:40px;--gc:#2A2D2E;" @ref="_canvasRef">
                    <!-- Links layer (SVG) -->
                    <svg class="wf-links-svg"
                         width="@_canvasWidth" height="@_canvasHeight"
                         viewBox="0 0 @(_canvasW) @(_canvasH)">
                        <defs>
                            <marker id="arrowhead" markerWidth="10" markerHeight="7"
                                    refX="9" refY="3.5" orient="auto">
                                <polygon points="0 0, 10 3.5, 0 7" fill="#60a5fa" />
                            </marker>
                        </defs>
                        @if (_session?.Tree?.Links is { } links)
                        {
                            @foreach (var link in links)
                            {
                                var pts = BuildLinkPoints(link);
                                <polyline class="wf-link-line"
                                          points="@pts"
                                          marker-end="url(#arrowhead)" />
                            }
                        }
                    </svg>

                    <!-- Nodes layer with drag support -->
                    @if (_session?.Tree?.Nodes is { } nodes)
                    {
                        var nodeIndex = 0;
                        @foreach (var node in nodes)
                        {
                            var ns = GetNodeStyle(node);
                            var idx = nodeIndex;
                            <div class="wf-node" style="@ns"
                                 data-node-index="@idx">
                                @switch (node)
                                {
                                    case ControllerViewModel c:
                                        @* Controller has output slot overlay *@
                                        <div style="position:relative;width:100%;height:100%;">
                                            <WorkflowControllerView Controller="c" />
                                            <div class="slot-overlay slot-output-overlay">
                                                <WorkflowSlotView Slot="c.OutputSlot" IsOutput="true" />
                                            </div>
                                        </div>
                                        break;
                                    case NodeViewModel w:
                                        <div style="position:relative;width:100%;height:100%;">
                                            <WorkflowNodeView Node="w" />
                                            <div class="slot-overlay slot-input-overlay">
                                                <WorkflowSlotView Slot="w.InputSlot" IsInput="true" />
                                            </div>
                                            <div class="slot-overlay slot-output-overlay">
                                                <WorkflowSlotView Slot="w.OutputSlot" IsOutput="true" />
                                            </div>
                                        </div>
                                        break;
                                    case BoolSelectorNodeViewModel b:
                                        <div style="position:relative;width:100%;height:100%;">
                                            <WorkflowBoolSelectorView Selector="b" />
                                            <div class="slot-overlay slot-input-overlay">
                                                <WorkflowSlotView Slot="b.InputSlot" IsInput="true" />
                                            </div>
                                        </div>
                                        break;
                                    case EnumSelectorNodeViewModel e:
                                        <div style="position:relative;width:100%;height:100%;">
                                            <WorkflowEnumSelectorView Selector="e" />
                                            <div class="slot-overlay slot-input-overlay">
                                                <WorkflowSlotView Slot="e.InputSlot" IsInput="true" />
                                            </div>
                                        </div>
                                        break;
                                }
                            </div>
                            nodeIndex++;
                        }
                    }
                </div>
            </WorkflowGridDecorator>

            @if (_jsReady && _session?.Tree is not null)
            {
                <WorkflowMinimapOverlay Tree="_session.Tree"
                                        Visible="true"
                                        Width="180" Height="120"
                                        ScrollOffsetX="_scrollLeft" ScrollOffsetY="_scrollTop"
                                        ContentOffsetX="0" ContentOffsetY="0"
                                        ViewportWidth="_viewportW" ViewportHeight="_viewportH"
                                        Background="#1C2330"
                                        BorderColor="#475569"
                                        NodeFill="#38BDF8"
                                        ViewportStroke="#FFFFFF" />
            }
        </div>
    </main>
</div>
