<UserControl x:Class="Demo.Views.Workflow.NodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Demo.Views.Workflow"
             xmlns:vm="clr-namespace:Demo.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="180" d:DesignWidth="220"
             d:DataContext="{d:DesignInstance Type=vm:NodeViewModel}">
    <Grid>
        <Border Background="#0F172A"
                CornerRadius="12"
                BorderBrush="#334155"
                BorderThickness="1" />

        <Grid Margin="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#111827"
                    CornerRadius="11,11,0,0"
                    BorderBrush="#1F2937"
                    BorderThickness="0,0,0,1"
                    MouseDown="OnMouseDown"
                    MouseUp="OnMouseUp"
                    MouseMove="OnMouseMove"
                    MouseLeave="OnMouseLeave">
                <Grid Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Title}"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <Border Grid.Column="1"
                            Padding="8,2"
                            Margin="8,0,0,0"
                            Background="#1D4ED8"
                            CornerRadius="8"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding ExecutionOrderText}"
                                   Foreground="White"
                                   FontSize="10"
                                   FontWeight="Bold" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="12,10,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Padding="8,2"
                            Background="#0B5ED7"
                            CornerRadius="8"
                            HorizontalAlignment="Left">
                        <TextBlock Text="{Binding Method}"
                                   Foreground="White"
                                   FontSize="10"
                                   FontWeight="Bold" />
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="{Binding LastStatus}"
                               Foreground="#93C5FD"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Grid>

                <TextBlock Grid.Row="1"
                           Margin="0,8,0,0"
                           Text="{Binding Url}"
                           Foreground="#E5E7EB"
                           FontSize="10"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           MaxHeight="30" />

                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding LastDuration, StringFormat=Duration: {0}}"
                               Foreground="#94A3B8"
                               FontSize="10" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding RunCount, StringFormat=Run: {0}}"
                               Foreground="#94A3B8"
                               FontSize="10"
                               HorizontalAlignment="Right" />
                </Grid>

                <TextBlock Grid.Row="3"
                           Margin="0,6,0,0"
                           Text="{Binding WaitCount, StringFormat=Queue: {0}}"
                           Foreground="#94A3B8"
                           FontSize="10" />

                <StackPanel Grid.Row="4" Margin="0,8,0,0">
                    <TextBlock Text="{Binding LastExecutionTrace, StringFormat=Trace: {0}}"
                               Foreground="#CBD5E1"
                               FontSize="10"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="28" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding LastResponsePreview, StringFormat=Preview: {0}}"
                               Foreground="#E2E8F0"
                               FontSize="10"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="40" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding LastError, StringFormat=Error: {0}}"
                               Foreground="#FCA5A5"
                               FontSize="10"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="28" />
                </StackPanel>
            </Grid>
        </Grid>

        <Grid>
            <ItemsControl ItemsSource="{Binding Slots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                                Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Offset.Left}" />
                        <Setter Property="Canvas.Top" Value="{Binding Offset.Top}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:SlotViewModel}">
                        <local:SlotView Width="{Binding Size.Width}"
                                        Height="{Binding Size.Height}"
                                        IsEnabled="{Binding IsEnabled}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>