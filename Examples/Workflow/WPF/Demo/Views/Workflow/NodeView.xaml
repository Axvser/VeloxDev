<UserControl x:Class="Demo.Views.Workflow.NodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Demo.Views.Workflow"
             mc:Ignorable="d"
             ClipToBounds="False"
             d:DesignHeight="260" d:DesignWidth="300">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid ClipToBounds="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
            <RowDefinition Height="54" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="3"
                CornerRadius="6"
                BorderThickness="1.5"
                BorderBrush="{Binding ChromeBorderBrush}"
                Background="{Binding ChromeBackground}" />

        <Grid Grid.RowSpan="3" Panel.ZIndex="6" ClipToBounds="False">
            <local:SlotView x:Name="PART_InputSlot"
                            Width="20"
                            Height="20"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="-10,0,0,0"
                            DataContext="{Binding InputSlot}"
                            Visibility="{Binding HasInputSlot, Converter={StaticResource BooleanToVisibilityConverter}}"
                            SlotState="{Binding State}" />

            <local:SlotView x:Name="PART_OutputSlot"
                            Width="20"
                            Height="20"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,-10,0"
                            DataContext="{Binding OutputSlot}"
                            Visibility="{Binding HasOutputSlot, Converter={StaticResource BooleanToVisibilityConverter}}"
                            SlotState="{Binding State}" />
        </Grid>

        <Border Grid.Row="0"
                Background="{Binding HeaderBackground}"
                CornerRadius="4,4,0,0"
                BorderThickness="0,0,0,0.5"
                BorderBrush="{Binding HeaderBorderBrush}"
                MouseLeftButtonDown="OnMouseDown"
                MouseLeftButtonUp="OnMouseUp"
                MouseMove="OnMouseMove"
                LostMouseCapture="OnLostMouseCapture">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Title}" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" />
                    <Border Margin="8,0,0,0"
                            Padding="6,1"
                            Background="#1F3D1F"
                            BorderBrush="#7BD97B"
                            BorderThickness="1"
                            CornerRadius="10"
                            Visibility="{Binding HasExecutionOrder, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding ExecutionOrderText}" Foreground="#C8FFC8" FontWeight="Bold" VerticalAlignment="Center" />
                    </Border>
                    <Border Margin="8,0,0,0"
                            Padding="6,1"
                            Background="#2B2440"
                            BorderBrush="#B799FF"
                            BorderThickness="1"
                            CornerRadius="10"
                            Visibility="{Binding HasWorkLoad, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding WorkLoadText}" Foreground="#E4D8FF" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="耗时" Foreground="#BFBFBF" FontSize="10" HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding LastDuration}" Foreground="{Binding DurationForeground}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#252525">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Delay" Foreground="#DCDCDC" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding DelayMilliseconds, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Title" Foreground="#DCDCDC" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <CheckBox IsChecked="{Binding AutoBroadcast}" Foreground="#DCDCDC" Content="执行完成后自动广播到下游" />

                    <Border Margin="0,10,0,0"
                            Background="{Binding ExecutionBackground}"
                            BorderBrush="{Binding ExecutionBorderBrush}"
                            BorderThickness="1.5"
                            CornerRadius="4"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="Execution" Foreground="#7EC8FF" FontWeight="Bold" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding RunCount, StringFormat=Active: {0}}" Foreground="#FFD54A" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding WaitCount, StringFormat=Queued: {0}}" Foreground="#D6B7FF" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding LastExecutionTrace, StringFormat=Order: {0}}" Foreground="#9EE79E" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding LastStatus, StringFormat=Status: {0}}" Foreground="White" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding LastDuration}" Foreground="{Binding DurationForeground}" FontSize="24" FontWeight="Bold" />
                            <TextBlock Text="{Binding LastError, StringFormat=Error: {0}}" Foreground="#FF9B9B" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding LastResponsePreview}" Foreground="#CFCFCF" TextWrapping="Wrap" MaxHeight="90" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Padding="1"
                Background="#2D2D2D"
                CornerRadius="0,0,4,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Run" Command="{Binding WorkCommand}" />
                <Button Grid.Column="1" Content="Forward" Command="{Binding BroadcastCommand}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>