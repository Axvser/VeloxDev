<UserControl x:Class="Demo.Views.Workflow.ControllerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
              xmlns:vm="clr-namespace:Demo.ViewModels;assembly=Lib"
              xmlns:local="clr-namespace:Demo.Views.Workflow"
              xmlns:behaviors="clr-namespace:VeloxDev.WorkflowSystem.AttachedBehaviors;assembly=VeloxDev.WPF"
             mc:Ignorable="d"
             ClipToBounds="False"
             d:DesignHeight="340" d:DesignWidth="220"
              behaviors:WorkflowSlotLayoutBehavior.IsEnabled="True"
              behaviors:WorkflowSlotLayoutBehavior.SlotNames="PART_OutputSlot"
              behaviors:WorkflowSlotLayoutBehavior.CoordinateHostName="PART_Canvas">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid ClipToBounds="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
            <RowDefinition Height="56" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="3"
                CornerRadius="5"
                BorderThickness="1"
                BorderBrush="White"
                Background="#2D2D2D" />

        <Border Grid.Row="0"
                CornerRadius="5,5,0,0"
                Background="#2D2D2D"
                behaviors:WorkflowNodeDragBehavior.CoordinateHostName="PART_Canvas"
                behaviors:WorkflowNodeDragBehavior.IsEnabled="True">
            <TextBlock Text="Network Flow Controller"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="White" />
        </Border>

        <Border Grid.Row="1"
                Background="#252525"
                Padding="12">
            <ScrollViewer>
            <StackPanel>
                <TextBlock Text="Seed" Foreground="#DCDCDC" FontSize="11" />
                <TextBox Margin="0,4,0,0" FontSize="11"
                         Text="{Binding SeedPayload, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,6,0,0" Text="Mode" Foreground="#DCDCDC" FontSize="11" />
                <ComboBox Margin="0,2,0,0" FontSize="11"
                          ItemsSource="{Binding CompileModeOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          SelectedItem="{Binding CompileMode}" />

                <TextBlock Margin="0,6,0,0" Text="Direction" Foreground="#DCDCDC" FontSize="11" />
                <ComboBox Margin="0,2,0,0" FontSize="11"
                          ItemsSource="{Binding CompileDirectionOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          SelectedItem="{Binding CompileDirection}" />

                <TextBlock Margin="0,6,0,0" Text="Scope" Foreground="#DCDCDC" FontSize="11" />
                <ComboBox Margin="0,2,0,0" FontSize="11"
                          ItemsSource="{Binding CompileScopeOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          SelectedItem="{Binding CompileScope}" />

                <TextBlock Margin="0,6,0,0" Text="Cycle" Foreground="#DCDCDC" FontSize="11" />
                <ComboBox Margin="0,2,0,0" FontSize="11"
                          ItemsSource="{Binding CycleHandlingOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          SelectedItem="{Binding CycleHandling}" />
            </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Background="#2D2D2D"
                CornerRadius="0,0,5,5"
                Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Margin="0,0,4,0"
                        Content="Run Flow"
                        Command="{Binding OpenWorkflowCommand}" />
                <Button Grid.Column="1"
                        Margin="4,0,0,0"
                        Content="Close Tree"
                        Command="{Binding CloseWorkflowCommand}" />
            </Grid>
        </Border>

        <local:SlotView x:Name="PART_OutputSlot"
                        Width="20"
                        Height="20"
                        Grid.RowSpan="3"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,-10,0"
                        DataContext="{Binding OutputSlot}"
                        Visibility="{Binding HasOutputSlot, Converter={StaticResource BooleanToVisibilityConverter}}"
                        SlotState="{Binding State}" />
    </Grid>
</UserControl>
