<UserControl x:Class="Demo.Views.Workflow.ControllerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Demo.Views.Workflow"
             mc:Ignorable="d"
             ClipToBounds="False"
             d:DesignHeight="170" d:DesignWidth="220">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid ClipToBounds="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
            <RowDefinition Height="56" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="3"
                CornerRadius="5"
                BorderThickness="1"
                BorderBrush="White"
                Background="#2D2D2D" />

        <Border Grid.Row="0"
                CornerRadius="5,5,0,0"
                Background="#2D2D2D"
                MouseLeftButtonDown="OnMouseDown"
                MouseLeftButtonUp="OnMouseUp"
                MouseMove="OnMouseMove"
                LostMouseCapture="OnLostMouseCapture">
            <TextBlock Text="Network Flow Controller"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="White" />
        </Border>

        <Border Grid.Row="1"
                Background="#252525"
                Padding="16">
            <StackPanel>
                <TextBlock Text="种子负载" Foreground="#DCDCDC" />
                <TextBox Margin="0,8,0,0"
                         Text="{Binding SeedPayload, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Margin="0,8,0,0"
                           Text="控制器节点只负责把初始上下文送入工作流。后续节点是否继续广播，仅由节点自身决定。"
                           Foreground="#BDBDBD"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#2D2D2D"
                CornerRadius="0,0,5,5"
                Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Margin="0,0,4,0"
                        Content="Run Flow"
                        Command="{Binding OpenWorkflowCommand}" />
                <Button Grid.Column="1"
                        Margin="4,0,0,0"
                        Content="Close Tree"
                        Command="{Binding CloseWorkflowCommand}" />
            </Grid>
        </Border>

        <local:SlotView x:Name="PART_OutputSlot"
                        Width="20"
                        Height="20"
                        Grid.RowSpan="3"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,-10,0"
                        DataContext="{Binding OutputSlot}"
                        Visibility="{Binding HasOutputSlot, Converter={StaticResource BooleanToVisibilityConverter}}"
                        SlotState="{Binding State}" />
    </Grid>
</UserControl>
