<UserControl x:Class="Demo.Views.Workflow.WorkflowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Demo.Views.Workflow"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1280">
    <UserControl.Resources>
        <DataTemplate x:Key="NodeTemplate">
            <local:NodeView Width="{Binding Size.Width}"
                            Height="{Binding Size.Height}"
                            IsEnabled="{Binding IsEnabled}"/>
        </DataTemplate>
        <DataTemplate x:Key="ControllerTemplate">
            <local:ControllerView Width="{Binding Size.Width}"
                                  Height="{Binding Size.Height}"
                                  IsEnabled="{Binding IsEnabled}"/>
        </DataTemplate>
        <DataTemplate x:Key="BoolSelectorTemplate">
            <local:BoolSelectorNodeView Width="{Binding Size.Width}"
                                        Height="{Binding Size.Height}"
                                        IsEnabled="{Binding IsEnabled}"/>
        </DataTemplate>
        <DataTemplate x:Key="EnumSelectorTemplate">
            <local:EnumSelectorNodeView Width="{Binding Size.Width}"
                                        Height="{Binding Size.Height}"
                                        IsEnabled="{Binding IsEnabled}"/>
        </DataTemplate>
        <DataTemplate x:Key="LinkTemplate">
            <local:BezierCurveView StartLeft="{Binding Sender.Anchor.Horizontal}"
                                   StartTop="{Binding Sender.Anchor.Vertical}"
                                   EndLeft="{Binding Receiver.Anchor.Horizontal}"
                                   EndTop="{Binding Receiver.Anchor.Vertical}"
                                   CanRender="{Binding IsVisible}"
                                   FlowColor="White"/>
        </DataTemplate>
        <local:CustomTemplateSelector x:Key="NodeSelector"
                                      Controller="{StaticResource ControllerTemplate}"
                                      Simulator="{StaticResource NodeTemplate}"
                                      BoolSelector="{StaticResource BoolSelectorTemplate}"
                                      EnumSelector="{StaticResource EnumSelectorTemplate}"
                                      Link="{StaticResource LinkTemplate}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="8*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="2">
            <Border Margin="0,20,20,20"
                    BorderBrush="White"
                    BorderThickness="1"
                    CornerRadius="3"
                    Background="#0B1120">
                <ScrollViewer x:Name="RootScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              PanningMode="Both"
                              PreviewMouseDown="OnCanvasPointerPressed"
                              MouseLeftButtonUp="OnPointerReleased"
                              PreviewMouseMove="OnPointerMoved"
                              PreviewMouseUp="OnPointerReleased"
                              ScrollChanged="OnScrollChanged">
                    <Canvas x:Name="WorkflowCanvas"
                            Width="{Binding Layout.ActualSize.Width}"
                            Height="{Binding Layout.ActualSize.Height}"
                            Background="#0F172A">
                    <ItemsControl ItemsSource="{Binding Helper.VisibleItems}"
                                  ItemTemplateSelector="{StaticResource NodeSelector}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Anchor.Horizontal, FallbackValue=0}" />
                                <Setter Property="Canvas.Top" Value="{Binding Anchor.Vertical, FallbackValue=0}" />
                                <Setter Property="Canvas.ZIndex" Value="{Binding Anchor.Layer, FallbackValue=-1}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                    </Canvas>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid Grid.Column="0" Margin="20,20,0,20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Button Content="Undo" Width="100" Height="50" Command="{Binding UndoCommand}" />
                    <Button Content="Redo" Width="100" Height="50" Margin="0,8,0,0" Command="{Binding RedoCommand}" />
                    <Button Content="Save" Width="100" Height="50" Margin="0,8,0,0" Click="SaveWorkflow" />
                    <Button Content="Select" Width="100" Height="50" Margin="0,8,0,0" Click="SelectWorkflow" />
                    <Button Content="Load Workflow Demo" Width="140" Height="50" Margin="0,8,0,0" Click="LoadNetworkDemo" />

                    <TextBlock Margin="0,12,0,0" Text="节点总数：" Foreground="White" />
                    <TextBlock Text="{Binding Nodes.Count}" Foreground="White" />
                    <TextBlock Margin="0,8,0,0" Text="可见组件数：( Node / Link )" Foreground="White" />
                    <TextBlock Text="{Binding Helper.VisibleItems.Count}" Foreground="White" />

                    <!-- Agent 对话 -->
                    <Border Margin="0,12,0,0"
                            Padding="10"
                            Background="#202020"
                            BorderBrush="#4C4C4C"
                            BorderThickness="1"
                            CornerRadius="4">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Agent 对话" Foreground="#7EC8FF" FontWeight="Bold" VerticalAlignment="Center" />
                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding UseStreamingAgentResponse}"
                                          Content="流式"
                                          Foreground="White"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <ListBox MaxHeight="300" x:Name="AgentLogScroller"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ItemsSource="{Binding AgentLog}"
                                     Background="Transparent" BorderThickness="0"
                                     VirtualizingStackPanel.IsVirtualizing="True"
                                     VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding .}" Foreground="#D8D8D8" TextWrapping="Wrap" Margin="0,2" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="AgentInput"
                                         Grid.Column="0"
                                         Background="#2D2D2D"
                                         Foreground="White"
                                         KeyDown="OnAgentInputKeyDown" />
                                <Button Grid.Column="1"
                                        Content="发送"
                                        Margin="4,0,0,0"
                                        Click="OnSendToAgent" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 执行记录 -->
                    <Border Margin="0,12,0,0"
                            Padding="10"
                            Background="#202020"
                            BorderBrush="#4C4C4C"
                            BorderThickness="1"
                            CornerRadius="4">
                        <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto" x:Name="ExecutionLogScroller">
                            <StackPanel>
                                <TextBlock Text="实际执行顺序" Foreground="#7EC8FF" FontWeight="Bold" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding ExecutionLog.Count, StringFormat=已记录: {0}}"
                                           Foreground="#BDBDBD" />
                                <ListBox Margin="0,6,0,0" ItemsSource="{Binding ExecutionLog}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                         VirtualizingStackPanel.IsVirtualizing="True"
                                         VirtualizingStackPanel.VirtualizationMode="Recycling">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding .}"
                                                       Foreground="#D8D8D8"
                                                       TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <GridSplitter Grid.Column="1"
                      Width="5"
                      Background="Gray"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" />
    </Grid>
</UserControl>