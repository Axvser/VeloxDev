<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="360"
			 x:Class="Demo.EnumSelectorNodeView"
			 xmlns:local="using:Demo"
			 xmlns:vm="using:Demo.ViewModels"
			 ClipToBounds="False"
			 x:DataType="vm:EnumSelectorNodeViewModel">
	<Grid RowDefinitions="48,*" ClipToBounds="False">
		<Border Grid.RowSpan="2"
				CornerRadius="6"
				BorderThickness="1.5"
				BorderBrush="#d6a0ff"
				Background="#2a1e35"/>
		<Grid Grid.RowSpan="2" ZIndex="6" ClipToBounds="False">
			<Grid.Styles>
				<Style Selector="local|SlotView">
					<Setter Property="Foreground" Value="White"/>
				</Style>
				<Style Selector="local|SlotView[SlotState=16]">
					<Setter Property="Foreground" Value="Lime"/>
				</Style>
			</Grid.Styles>
			<local:SlotView x:Name="PART_InputSlot"
							Width="20" Height="20"
							HorizontalAlignment="Left"
							VerticalAlignment="Center"
							Margin="-10,0,0,0"
							DataContext="{Binding InputSlot}"
							IsVisible="{Binding $parent[local:EnumSelectorNodeView].DataContext.HasInputSlot}"
							SlotState="{Binding State}"/>
		</Grid>
		<Border Grid.Row="0"
				Background="#3a2550"
				CornerRadius="4,4,0,0"
				BorderThickness="0,0,0,0.5"
				BorderBrush="#d6a0ff"
				PointerPressed="OnPointerPressed"
				PointerReleased="OnPointerReleased"
				PointerMoved="OnPointerMoved"
				PointerCaptureLost="OnPointerCaptureLost">
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
				<TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold"/>
				<Border Background="#2b1540" BorderBrush="#d6a0ff" BorderThickness="1" CornerRadius="10" Padding="6,1">
					<TextBlock Text="{Binding LastRouted}" Foreground="#e4d8ff" FontWeight="Bold"/>
				</Border>
			</StackPanel>
		</Border>
		<Border Grid.Row="1" Background="#2a1e35" CornerRadius="0,0,4,4">
			<StackPanel Margin="14" Spacing="8">
				<TextBlock Text="Selected Method" Foreground="#bfbfbf" FontSize="11"/>
				<ComboBox ItemsSource="{Binding EnumValues}"
						  SelectedItem="{Binding SelectedValue, Mode=TwoWay}"
						  HorizontalAlignment="Stretch"/>
				<TextBlock Text="Output Slots" Foreground="#bfbfbf" FontSize="11" Margin="0,6,0,0"/>
				<ItemsControl ItemsSource="{Binding OutputSlots}" x:Name="PART_OutputSlotsList" ClipToBounds="False">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Grid ColumnDefinitions="*,Auto" Margin="0,2" ClipToBounds="False">
								<TextBlock Grid.Column="0" Foreground="#d6a0ff" FontWeight="SemiBold"
										   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
								<local:SlotView Grid.Column="1" Width="16" Height="16"
												HorizontalAlignment="Right"
												VerticalAlignment="Center"
												Margin="0,0,-8,0"
												SlotState="{Binding State}"/>
							</Grid>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>
		</Border>
	</Grid>
</UserControl>
