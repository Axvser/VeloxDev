<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="450"
			 x:Class="Demo.ControllerView"
			 xmlns:local="using:Demo"
			 xmlns:vm="using:Demo.ViewModels"
            ClipToBounds="False"
			 x:DataType="vm:ControllerViewModel">
  <Grid RowDefinitions="52,*,56" ColumnDefinitions="*" ClipToBounds="False">
		<Border Grid.RowSpan="5"
             Grid.ColumnSpan="2"
				BorderThickness="1"
				CornerRadius="5"
				BorderBrush="White"
				Background="#2d2d2d" />
		<Border Grid.Row="0"
				Grid.ColumnSpan="2"
				BorderThickness="1"
				CornerRadius="5,5,0,0"
				Background="#2d2d2d"
				PointerPressed="OnPointerPressed"
				PointerReleased="OnPointerReleased"
				PointerMoved="OnPointerMoved"
				PointerCaptureLost="OnPointerCaptureLost">
         <TextBlock Text="Network Flow Controller"
					   VerticalAlignment="Center"
					   HorizontalAlignment="Center"
					   Foreground="White"/>
		</Border>

        <Border Grid.Row="1" Background="#252525" Padding="16">
			<StackPanel Spacing="10">
               <TextBlock Text="种子负载" Foreground="#dcdcdc"/>
				<TextBox Text="{Binding SeedPayload, Mode=TwoWay}" Watermark="用于初始化链路的上下文种子"/>
             <TextBlock Text="控制器节点只负责把初始上下文送入工作流。后续节点是否继续广播，仅由节点自身决定。"
						   Foreground="#bdbdbd"
						   TextWrapping="Wrap"/>
			</StackPanel>
		</Border>

		<Border Grid.Row="2" Background="#2d2d2d" CornerRadius="0,0,5,5" Padding="8">
			<Grid ColumnDefinitions="*,*" ColumnSpacing="8">
				<Button Grid.Column="0"
						Content="Run Flow"
						VerticalContentAlignment="Center"
						Background="#1e1e1e"
						Foreground="White"
						Command="{Binding OpenWorkflowCommand}"/>
				<Button Grid.Column="1"
						Content="Close Tree"
						VerticalContentAlignment="Center"
						Background="#1e1e1e"
						Foreground="White"
						Command="{Binding CloseWorkflowCommand}"/>
			</Grid>
		</Border>

     <local:SlotView x:Name="PART_OutputSlot"
					 Width="20"
					 Height="20"
					 Grid.RowSpan="3"
					 HorizontalAlignment="Right"
					 VerticalAlignment="Center"
					 Margin="0,0,-10,0"
					 DataContext="{Binding OutputSlot}"
					 SlotState="{Binding State}"/>
	</Grid>
</UserControl>
