<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="450"
			 x:Class="Demo.ControllerView"
			 xmlns:local="using:Demo"
            xmlns:behaviors="using:VeloxDev.WorkflowSystem.AttachedBehaviors"
			 xmlns:vm="using:Demo.ViewModels"
             ClipToBounds="False"
           behaviors:WorkflowSlotLayoutBehavior.IsEnabled="True"
			 behaviors:WorkflowSlotLayoutBehavior.SlotNames="PART_OutputSlot"
			 behaviors:WorkflowSlotLayoutBehavior.CoordinateHostName="PART_Canvas"
			 x:DataType="vm:ControllerViewModel">
  <Grid RowDefinitions="52,*,56" ColumnDefinitions="*" ClipToBounds="False">
		<Border Grid.RowSpan="5"
             Grid.ColumnSpan="2"
				BorderThickness="1"
				CornerRadius="5"
				BorderBrush="White"
				Background="#2d2d2d" />
		<Border Grid.Row="0"
				Grid.ColumnSpan="2"
				BorderThickness="1"
				CornerRadius="5,5,0,0"
				Background="#2d2d2d"
                behaviors:WorkflowNodeDragBehavior.CoordinateHostName="PART_Canvas"
				behaviors:WorkflowNodeDragBehavior.IsEnabled="True">
         <TextBlock Text="Network Flow Controller"
					   VerticalAlignment="Center"
					   HorizontalAlignment="Center"
					   Foreground="White"/>
		</Border>

        <Border Grid.Row="1" Background="#252525" Padding="12">
			<ScrollViewer>
			<StackPanel Spacing="6">
               <TextBlock Text="Seed" Foreground="#dcdcdc" FontSize="11"/>
				<TextBox Text="{Binding SeedPayload, Mode=TwoWay}" Watermark="payload" FontSize="11"/>

               <TextBlock Text="Mode" Foreground="#dcdcdc" FontSize="11"/>
				<ComboBox ItemsSource="{Binding CompileModeOptions}"
						  SelectedItem="{Binding CompileMode}" FontSize="11"/>

               <TextBlock Text="Direction" Foreground="#dcdcdc" FontSize="11"/>
				<ComboBox ItemsSource="{Binding CompileDirectionOptions}"
						  SelectedItem="{Binding CompileDirection}" FontSize="11"/>

               <TextBlock Text="Scope" Foreground="#dcdcdc" FontSize="11"/>
				<ComboBox ItemsSource="{Binding CompileScopeOptions}"
						  SelectedItem="{Binding CompileScope}" FontSize="11"/>

               <TextBlock Text="Cycle" Foreground="#dcdcdc" FontSize="11"/>
				<ComboBox ItemsSource="{Binding CycleHandlingOptions}"
						  SelectedItem="{Binding CycleHandling}" FontSize="11"/>
			</StackPanel>
			</ScrollViewer>
		</Border>

		<Border Grid.Row="2" Background="#2d2d2d" CornerRadius="0,0,5,5" Padding="8">
			<Grid ColumnDefinitions="*,*" ColumnSpacing="8">
				<Button Grid.Column="0"
						Content="Run Flow"
						VerticalContentAlignment="Center"
						Background="#1e1e1e"
						Foreground="White"
						Command="{Binding OpenWorkflowCommand}"/>
				<Button Grid.Column="1"
						Content="Close Tree"
						VerticalContentAlignment="Center"
						Background="#1e1e1e"
						Foreground="White"
						Command="{Binding CloseWorkflowCommand}"/>
			</Grid>
		</Border>

     <local:SlotView x:Name="PART_OutputSlot"
					 Width="20"
					 Height="20"
					 Grid.RowSpan="3"
					 HorizontalAlignment="Right"
					 VerticalAlignment="Center"
					 Margin="0,0,-10,0"
					 DataContext="{Binding OutputSlot}"
					 SlotState="{Binding State}"/>
	</Grid>
</UserControl>
