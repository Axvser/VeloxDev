<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="Demo.WorkflowView"
			 xmlns:local="using:Demo"
			 xmlns:behaviors="using:VeloxDev.WorkflowSystem.AttachedBehaviors"
			 xmlns:vm="using:Demo.ViewModels"
			 xmlns:workflow="using:VeloxDev.WorkflowSystem"
			 xmlns:csharp="using:VeloxDev.WorkflowSystem.CSharp"
			 x:DataType="vm:TreeViewModel"
             behaviors:WorkflowSurfaceBehavior.IsEnabled="True"
			 behaviors:WorkflowSurfaceBehavior.ScrollViewerName="PART_ScrollViewer"
			 behaviors:WorkflowSurfaceBehavior.CanvasName="PART_Canvas"
			 behaviors:WorkflowSurfaceBehavior.GridDecoratorName="PART_GridDecorator"
			 behaviors:WorkflowSurfaceBehavior.PointerPressSourceName="PART_SurfaceBorder">

	<!-- 模板 -->
	<UserControl.DataTemplates>
		<!-- 节点模板 -->
		<DataTemplate DataType="vm:NodeViewModel">
			<local:NodeView Width="{Binding Size.Width}"
							Height="{Binding Size.Height}"
							Canvas.Left="{Binding Anchor.Horizontal}"
							Canvas.Top="{Binding Anchor.Vertical}"
							ZIndex="{Binding Anchor.Layer}"
							RenderTransform="{Binding $parent[local:WorkflowView].(behaviors:WorkflowCanvasTransformBehavior.Transform)}"/>
		</DataTemplate>
		<DataTemplate DataType="vm:ControllerViewModel">
			<local:ControllerView Width="{Binding Size.Width}"
								  Height="{Binding Size.Height}"
								  Canvas.Left="{Binding Anchor.Horizontal}"
								  Canvas.Top="{Binding Anchor.Vertical}"
								  ZIndex="{Binding Anchor.Layer}"
								  RenderTransform="{Binding $parent[local:WorkflowView].(behaviors:WorkflowCanvasTransformBehavior.Transform)}"/>
		</DataTemplate>
		<DataTemplate DataType="vm:BoolSelectorNodeViewModel">
			<local:BoolSelectorNodeView Width="{Binding Size.Width}"
										Height="{Binding Size.Height}"
										Canvas.Left="{Binding Anchor.Horizontal}"
										Canvas.Top="{Binding Anchor.Vertical}"
										ZIndex="{Binding Anchor.Layer}"
										RenderTransform="{Binding $parent[local:WorkflowView].(behaviors:WorkflowCanvasTransformBehavior.Transform)}"/>
		</DataTemplate>
		<DataTemplate DataType="vm:EnumSelectorNodeViewModel">
			<local:EnumSelectorNodeView Width="{Binding Size.Width}"
										Height="{Binding Size.Height}"
										Canvas.Left="{Binding Anchor.Horizontal}"
										Canvas.Top="{Binding Anchor.Vertical}"
										ZIndex="{Binding Anchor.Layer}"
										RenderTransform="{Binding $parent[local:WorkflowView].(behaviors:WorkflowCanvasTransformBehavior.Transform)}"/>
		</DataTemplate>
		<DataTemplate DataType="csharp:CSharpObject">
			<local:CSharpObjectView Width="{Binding Size.Width}"
									Height="{Binding Size.Height}"
									Canvas.Left="{Binding Anchor.Horizontal}"
									Canvas.Top="{Binding Anchor.Vertical}"
									ZIndex="{Binding Anchor.Layer}"
									RenderTransform="{Binding $parent[local:WorkflowView].(behaviors:WorkflowCanvasTransformBehavior.Transform)}"/>
		</DataTemplate>
		<!-- 连接线模板 -->
		<DataTemplate DataType="vm:LinkViewModel">
			<Panel>
				<local:BezierCurveView StartLeft="{Binding Sender.Anchor.Horizontal}"
									   StartTop="{Binding Sender.Anchor.Vertical}"
									   EndLeft="{Binding Receiver.Anchor.Horizontal}"
									   EndTop="{Binding Receiver.Anchor.Vertical}"
									   CanRender="{Binding IsVisible}"
									   IsVisible="{Binding !UsePolyline}"
									   Width="{Binding $parent[Canvas].Bounds.Width}"
									   Height="{Binding $parent[Canvas].Bounds.Height}"
									   RenderTransform="{Binding $parent[local:WorkflowView].(behaviors:WorkflowCanvasTransformBehavior.Transform)}"
									   ZIndex="-1"/>
				<local:PolylineCurveView StartLeft="{Binding Sender.Anchor.Horizontal}"
										 StartTop="{Binding Sender.Anchor.Vertical}"
										 EndLeft="{Binding Receiver.Anchor.Horizontal}"
										 EndTop="{Binding Receiver.Anchor.Vertical}"
										 CanRender="{Binding IsVisible}"
										 IsVisible="{Binding UsePolyline}"
										 Width="{Binding $parent[Canvas].Bounds.Width}"
										 Height="{Binding $parent[Canvas].Bounds.Height}"
										 RenderTransform="{Binding $parent[local:WorkflowView].(behaviors:WorkflowCanvasTransformBehavior.Transform)}"
										 ZIndex="-1"/>
			</Panel>
		</DataTemplate>
		<DataTemplate DataType="workflow:IWorkflowLinkViewModel">
			<local:BezierCurveView StartLeft="{Binding Sender.Anchor.Horizontal}"
								   StartTop="{Binding Sender.Anchor.Vertical}"
								   EndLeft="{Binding Receiver.Anchor.Horizontal}"
								   EndTop="{Binding Receiver.Anchor.Vertical}"
								   CanRender="{Binding IsVisible}"
								   Width="{Binding $parent[Canvas].Bounds.Width}"
								   Height="{Binding $parent[Canvas].Bounds.Height}"
								   RenderTransform="{Binding $parent[local:WorkflowView].(behaviors:WorkflowCanvasTransformBehavior.Transform)}"
								   ZIndex="-1"/>
		</DataTemplate>
	</UserControl.DataTemplates>

	<Grid ColumnDefinitions="2*,auto,8*">
		<!-- 渲染节点编辑器 ( 虚拟化支持 + Minimap 缩略图 ) -->
		<Grid Grid.Column="2" x:Name="WorkflowContainer">
			<Border x:Name="PART_SurfaceBorder" BorderBrush="White" BorderThickness="1" CornerRadius="3">
			   <local:WorkflowGridDecorator x:Name="PART_GridDecorator">
				  <ScrollViewer HorizontalScrollBarVisibility="Auto"
								 x:Name="PART_ScrollViewer">
						<Canvas x:DataType="vm:TreeViewModel"
								x:Name="PART_Canvas"
								Width="{Binding Layout.ActualSize.Width}"
								Height="{Binding Layout.ActualSize.Height}"
								HorizontalAlignment="Left"
								VerticalAlignment="Top"
							 behaviors:ViewPool.ItemsSource="{Binding Helper.VisibleItems}">
							<Canvas.DataTemplates>
								<!-- 依照优先级寻找数据模板 >> Self > Parent > App -->
							</Canvas.DataTemplates>
						</Canvas>
					</ScrollViewer>
				</local:WorkflowGridDecorator>
			</Border>
			<!-- Minimap: positioned below ruler, with equal gap from ruler & right edge -->
			<behaviors:WorkflowMinimapOverlay x:Name="PART_MinimapOverlay"
											  HorizontalAlignment="Right"
											  VerticalAlignment="Top"
											  Margin="0,36,8,0"
											  ScrollViewerName="PART_ScrollViewer"
											  IsHitTestVisible="True"
											  WorkflowTree="{Binding}"
											  ScrollOffsetX="{Binding ScrollOffsetX, ElementName=PART_GridDecorator}"
											  ScrollOffsetY="{Binding ScrollOffsetY, ElementName=PART_GridDecorator}"
											  ContentOffsetX="{Binding ContentOffsetX, ElementName=PART_GridDecorator}"
											  ContentOffsetY="{Binding ContentOffsetY, ElementName=PART_GridDecorator}"
											  ViewportWidth="{Binding Bounds.Width, ElementName=WorkflowContainer}"
											  ViewportHeight="{Binding Bounds.Height, ElementName=WorkflowContainer}"/>
		</Grid>

		<!-- 功能按键 ( 测试用 ) -->
		<Grid Grid.Column="0">
			<ScrollViewer>
				<StackPanel Orientation="Vertical">
					<Button Content="Undo" Width="100" Height="50" Command="{Binding UndoCommand}" />
					<Button Content="Redo" Width="100" Height="50" Command="{Binding RedoCommand}" />
					<Button Content="Save" Width="100" Height="50" Click="SaveWorkflow" />
					<Button Content="Select" Width="100" Height="50" Click="SelectWorkflow" />
					<Button Content="Load Workflow Demo" Width="140" Height="50" Click="LoadNetworkDemo" />
					<Button Content="Add C# Script Chain" Width="160" Height="50" Click="AddCSharpObject" />
					<Button Content="Run C# Script" Width="160" Height="50" Click="RunCSharpPipeline" />
						<TextBlock Text="节点总数：" />
						<TextBlock Text="{Binding Nodes.Count}"/>
						<TextBlock Text="可见组件数：( Node / Link )" />
						<TextBlock Text="{Binding Helper.VisibleItems.Count}" />
						<!-- Minmap toggle -->
						<Grid Margin="0,6,0,0" ColumnDefinitions="*,Auto">
							<TextBlock Text="小地图" VerticalAlignment="Center"/>
							<ToggleSwitch Grid.Column="1"
										  IsChecked="{Binding IsMinimapVisible, ElementName=PART_MinimapOverlay}"/>
						</Grid>
						<!-- Agent 对话 -->
						<Border Margin="0,12,0,0" Padding="10" Background="#202020" BorderBrush="#4c4c4c" BorderThickness="1" CornerRadius="4">
							<StackPanel Spacing="6">
								<Grid ColumnDefinitions="*,Auto">
									<TextBlock Text="Agent 对话" Foreground="#7ec8ff" FontWeight="Bold"/>
									<ToggleSwitch Grid.Column="1"
												  IsChecked="{Binding UseStreamingAgentResponse}"
												  OnContent="流式"
												  OffContent="普通"
												  FontSize="11"
												  Margin="0,-6,0,-6"/>
								</Grid>
								<ListBox MaxHeight="300" x:Name="AgentLogScroller"
										 VerticalAlignment="Stretch"
										 ScrollViewer.VerticalScrollBarVisibility="Auto"
										 ItemsSource="{Binding AgentLog}"
										 Background="Transparent" BorderThickness="0">
										<ListBox.ItemsPanel>
											<ItemsPanelTemplate>
												<VirtualizingStackPanel/>
											</ItemsPanelTemplate>
										</ListBox.ItemsPanel>
										<ListBox.ItemTemplate>
											<DataTemplate>
												<TextBlock Text="{Binding .}" Foreground="#d8d8d8" TextWrapping="Wrap" Margin="0,2"/>
											</DataTemplate>
										</ListBox.ItemTemplate>
									</ListBox>
								<Grid ColumnDefinitions="*,Auto">
									<TextBox x:Name="AgentInput"
											 Grid.Column="0"
											 Watermark="输入消息..."
											 Background="#2d2d2d"
											 Foreground="White"
											 AcceptsReturn="False"
											 KeyDown="OnAgentInputKeyDown"/>
									<Button Grid.Column="1"
											Content="发送"
											Margin="4,0,0,0"
											Click="OnSendToAgent"/>
								</Grid>
							</StackPanel>
						</Border>
						<!-- 执行记录 -->
						<Border Margin="0,12,0,0" Padding="10" Background="#202020" BorderBrush="#4c4c4c" BorderThickness="1" CornerRadius="4">
							<ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto" x:Name="ExecutionLogScroller">
								<StackPanel Spacing="6">
									<TextBlock Text="实际执行顺序" Foreground="#7ec8ff" FontWeight="Bold"/>
									<TextBlock Text="{Binding ExecutionLog.Count, StringFormat=已记录: {0}}" Foreground="#bdbdbd"/>
									<ListBox ItemsSource="{Binding ExecutionLog}"
											 Background="Transparent" BorderThickness="0"
											 ScrollViewer.VerticalScrollBarVisibility="Disabled">
										<ListBox.ItemsPanel>
											<ItemsPanelTemplate>
												<VirtualizingStackPanel/>
											</ItemsPanelTemplate>
										</ListBox.ItemsPanel>
										<ListBox.ItemTemplate>
											<DataTemplate>
												<TextBlock Text="{Binding .}" Foreground="#d8d8d8" TextWrapping="Wrap"/>
											</DataTemplate>
										</ListBox.ItemTemplate>
									</ListBox>
								</StackPanel>
							</ScrollViewer>
						</Border>
				</StackPanel>
			</ScrollViewer>
		</Grid>

		<GridSplitter Grid.Column="1" Width="5" Background="Gray"/>
	</Grid>
</UserControl>
