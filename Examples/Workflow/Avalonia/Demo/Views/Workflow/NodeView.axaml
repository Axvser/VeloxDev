<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="450"
			 x:Class="Demo.NodeView"
			 xmlns:local="using:Demo"
			 xmlns:vm="using:Demo.ViewModels"
          ClipToBounds="False"
			 x:DataType="vm:NodeViewModel">
    <Grid RowDefinitions="52,*,54" ClipToBounds="False">
		<Border Grid.RowSpan="3"
				CornerRadius="6"
				BorderThickness="1.5"
               BorderBrush="{Binding ChromeBorderBrush}"
				Background="{Binding ChromeBackground}">
		</Border>

		<Grid Grid.RowSpan="3" ZIndex="6" ClipToBounds="False">
			<Grid.Styles>
				<Style Selector="local|SlotView">
					<Setter Property="Foreground" Value="White"/>
				</Style>
				<Style Selector="local|SlotView[SlotState=8]">
					<Setter Property="Foreground" Value="Tomato"/>
				</Style>
				<Style Selector="local|SlotView[SlotState=16]">
					<Setter Property="Foreground" Value="Lime"/>
				</Style>
				<Style Selector="local|SlotView[SlotState=24]">
					<Setter Property="Foreground" Value="Violet"/>
				</Style>
			</Grid.Styles>

			<local:SlotView x:Name="PART_InputSlot"
						 Width="20"
						 Height="20"
						 HorizontalAlignment="Left"
						 VerticalAlignment="Center"
						 Margin="-10,0,0,0"
						 DataContext="{Binding InputSlot}"
                       IsVisible="{Binding $parent[local:NodeView].DataContext.HasInputSlot}"
						 SlotState="{Binding State}"/>

			<local:SlotView x:Name="PART_OutputSlot"
						 Width="20"
						 Height="20"
						 HorizontalAlignment="Right"
						 VerticalAlignment="Center"
						 Margin="0,0,-10,0"
						 DataContext="{Binding OutputSlot}"
                       IsVisible="{Binding $parent[local:NodeView].DataContext.HasOutputSlot}"
						 SlotState="{Binding State}"/>
		</Grid>

		<!-- 标题栏 -->
		<Border Grid.Row="0"
                Background="{Binding HeaderBackground}"
				CornerRadius="4,4,0,0"
				BorderThickness="0,0,0,0.5"
              BorderBrush="{Binding HeaderBorderBrush}"
				PointerPressed="OnPointerPressed"
				PointerReleased="OnPointerReleased"
				PointerMoved="OnPointerMoved"
				PointerCaptureLost="OnPointerCaptureLost">
			<Grid ColumnDefinitions="*,Auto" Margin="12,0">
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
					<TextBlock Text="{Binding Title}" Foreground="White" VerticalAlignment="Center" FontWeight="Bold"/>
                   <Border Background="#1f3d1f"
							BorderBrush="#7bd97b"
							BorderThickness="1"
							CornerRadius="10"
							Padding="6,1"
							IsVisible="{Binding HasExecutionOrder}">
						<TextBlock Text="{Binding ExecutionOrderText}" Foreground="#c8ffc8" FontWeight="Bold" VerticalAlignment="Center"/>
					</Border>
                   <Border Background="#2b2440"
							BorderBrush="#b799ff"
							BorderThickness="1"
							CornerRadius="10"
							Padding="6,1"
							IsVisible="{Binding HasWorkLoad}">
                     <TextBlock Text="{Binding WorkLoadText}" Foreground="#e4d8ff" FontWeight="SemiBold" VerticalAlignment="Center"/>
					</Border>
				</StackPanel>
				<StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="0">
					<TextBlock Text="耗时" Foreground="#bfbfbf" FontSize="10" HorizontalAlignment="Right"/>
                 <TextBlock Text="{Binding LastDuration}" Foreground="{Binding DurationForeground}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"/>
				</StackPanel>
			</Grid>
		</Border>

       <Border Grid.Row="1" Background="#252525">
			<ScrollViewer VerticalScrollBarVisibility="Auto">
				<StackPanel Margin="14" Spacing="10">
					<Grid ColumnDefinitions="110,*">
                      <TextBlock Text="Delay" Foreground="#dcdcdc" VerticalAlignment="Center"/>
						<NumericUpDown Grid.Column="1"
								   Minimum="100"
								   Maximum="10000"
								   Increment="100"
								   Value="{Binding DelayMilliseconds, Mode=TwoWay}"/>
					</Grid>

                    <Grid ColumnDefinitions="110,*">
						<TextBlock Text="Title" Foreground="#dcdcdc" VerticalAlignment="Center"/>
						<TextBox Grid.Column="1" Text="{Binding Title, Mode=TwoWay}"/>
					</Grid>

                    <CheckBox IsChecked="{Binding AutoBroadcast, Mode=TwoWay}" Content="执行完成后自动广播到下游" Foreground="#dcdcdc"/>

                    <Border Background="{Binding ExecutionBackground}" BorderBrush="{Binding ExecutionBorderBrush}" BorderThickness="1.5" CornerRadius="4" Padding="10">
						<StackPanel Spacing="4">
							<TextBlock Text="Execution" Foreground="#7ec8ff" FontWeight="Bold"/>
                           <TextBlock Text="{Binding RunCount, StringFormat=Active: {0}}" Foreground="#ffd54a" FontWeight="SemiBold"/>
							<TextBlock Text="{Binding WaitCount, StringFormat=Queued: {0}}" Foreground="#d6b7ff" FontWeight="SemiBold"/>
                          <TextBlock Text="{Binding LastExecutionTrace, StringFormat=Order: {0}}"
									   Foreground="#9ee79e"
									   FontWeight="SemiBold"
									   TextWrapping="Wrap"/>
							<TextBlock Text="{Binding LastStatus, StringFormat=Status: {0}}"
									   Foreground="White"
									   FontWeight="SemiBold"/>
							<TextBlock Text="{Binding LastDuration}"
									   Foreground="{Binding DurationForeground}"
									   FontSize="24"
									   FontWeight="Bold"/>
							<TextBlock Text="{Binding LastError, StringFormat=Error: {0}}" Foreground="#ff9b9b" TextWrapping="Wrap"/>
							<TextBlock Text="{Binding LastResponsePreview}" Foreground="#cfcfcf" TextWrapping="Wrap" MaxHeight="90"/>
						</StackPanel>
					</Border>
				</StackPanel>
			</ScrollViewer>
		</Border>

		<!-- 功能按键 -->
        <Border Grid.Row="2"
				Padding="1"
				Background="#2d2d2d"
				CornerRadius="0,0,4,4">
          <Grid ColumnDefinitions="*,*,*">
				<Button Grid.Column="0" Content="Run" Command="{Binding WorkCommand}" Foreground="White" HorizontalAlignment="Stretch"/>
				<Button Grid.Column="1" Content="Forward" Command="{Binding BroadcastCommand}" Foreground="White" HorizontalAlignment="Stretch"/>
			</Grid>
		</Border>
	</Grid>
</UserControl>
