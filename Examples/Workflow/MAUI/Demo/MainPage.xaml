<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Demo.Controls"
             x:Class="Demo.MainPage"
             Title="Workflow"
             BackgroundColor="#020617">

    <Grid ColumnDefinitions="360,12,*" Padding="20">
        <ScrollView>
            <VerticalStackLayout Spacing="16">
                <Border BackgroundColor="#111827"
                        Padding="16"
                        Stroke="#334155"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="VeloxDev Workflow Demo"
                               FontAttributes="Bold"
                               FontSize="24"
                               TextColor="White" />
                        <Label Text="MAUI 版本对齐桌面端 Workflow 设计：附加属性驱动、对象池渲染与一致的工作流画布外观。"
                               FontSize="14"
                               TextColor="#CBD5E1" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                            <Label Text="Seed Payload"
                                   TextColor="#E2E8F0"
                                   FontAttributes="Bold"
                                   Grid.ColumnSpan="2" />

                            <Entry Grid.Row="1"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding Controller.SeedPayload}"
                                   Placeholder="demo-request-chain"
                                   ClearButtonVisibility="WhileEditing" />

                            <Button Grid.Row="2"
                                    Text="运行"
                                    Clicked="RunWorkflowAsync" />
                            <Button Grid.Row="2"
                                    Grid.Column="1"
                                    Text="停止"
                                    Clicked="StopWorkflowAsync" />
                            <Button Grid.Row="3"
                                    Text="重置"
                                    Clicked="ReloadDemoAsync" />
                            <Button Grid.Row="3"
                                    Grid.Column="1"
                                    Text="Undo"
                                    Command="{Binding Tree.UndoCommand}" />
                            <Button Grid.Row="4"
                                    Text="Add C# Script Chain"
                                    Clicked="AddCSharpObject" />
                            <Button Grid.Row="4"
                                    Grid.Column="1"
                                    Text="Redo"
                                    Command="{Binding Tree.RedoCommand}" />
                            <Button Grid.Row="5"
                                    Grid.ColumnSpan="2"
                                    Text="Run C# Script"
                                    Clicked="RunCSharpPipeline" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#111827"
                        Padding="16"
                        Stroke="#334155"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18">
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Agent 对话"
                                   FontAttributes="Bold"
                                   FontSize="18"
                                   TextColor="#7EC8FF" />
                            <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <Label Text="流式" TextColor="#CBD5E1" VerticalTextAlignment="Center" />
                                <Switch IsToggled="{Binding Tree.UseStreamingAgentResponse}" />
                            </HorizontalStackLayout>
                        </Grid>
                        <CollectionView Grid.Row="1"
                                        x:Name="AgentLogScroller"
                                        HeightRequest="220"
                                        VerticalScrollBarVisibility="Always"
                                        ItemsSource="{Binding Tree.AgentLog}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding .}"
                                           FontFamily="OpenSansRegular"
                                           TextColor="#D8D8D8"
                                           Margin="0,2" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Entry x:Name="AgentInput"
                                   Placeholder="输入消息..."
                                   BackgroundColor="#2D2D2D"
                                   TextColor="White"
                                   Completed="OnAgentInputCompleted" />
                            <Button Grid.Column="1"
                                    Text="发送"
                                    Clicked="OnSendToAgent" />
                        </Grid>
                    </Grid>
                </Border>

                <Border BackgroundColor="#111827"
                        Padding="16"
                        Stroke="#334155"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18">
                    <Grid RowDefinitions="Auto,*" RowSpacing="12">
                        <Label Text="Execution Log"
                               FontAttributes="Bold"
                               FontSize="18"
                               TextColor="#7EC8FF" />

                        <CollectionView Grid.Row="1"
                                        HeightRequest="240"
                                        ItemsSource="{Binding ExecutionLog}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding .}"
                                           FontFamily="OpenSansRegular"
                                           TextColor="#E2E8F0"
                                           Margin="0,2" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <BoxView Grid.Column="1" Color="#334155" WidthRequest="1" HorizontalOptions="Center" />

        <Border Grid.Column="2"
                BackgroundColor="#0B1120"
                Padding="0"
                Margin="0,0,0,0"
                Stroke="#1E293B"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 18">
            <controls:WorkflowView Session="{Binding DemoSession}" />
        </Border>
    </Grid>

</ContentPage>
