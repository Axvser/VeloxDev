@page "/"
@rendermode InteractiveServer

<PageTitle>VeloxDev Transition — Blazor Demo</PageTitle>

<div class="demo-root">
    <h2 class="demo-title">VeloxDev Transition · Blazor</h2>
    <p class="demo-desc">
        VeloxDev 动画的核心概念是 <strong>"一切皆状态"</strong>。
        动画直接作用于 C# 对象的属性，Blazor 通过 PropertyChanged 驱动 UI 重渲染。
    </p>

    <div class="demo-toolbar">
        <button class="btn btn-primary" @onclick="LoadAnimations">▶ Load Animations</button>
        <button class="btn btn-secondary" @onclick="ResetBox0">↩ Reset Box0</button>
        <button class="btn btn-danger" @onclick="ExitAnimations">■ Exit Animations</button>
    </div>

    <div class="demo-stage">
        <!-- Box0: 简单动画 — 位移 + 颜色 + 透明度 -->
        <div class="box-row">
            <span class="box-label">Box0 · 位移 + 颜色 + 透明度</span>
            <div class="box-track">
                <div class="box" style="@Box0.Style"></div>
            </div>
        </div>

        <!-- Box1: 延迟动画 — 等待 2s 后旋转 + 缩放 -->
        <div class="box-row">
            <span class="box-label">Box1 · 延迟 2s · 旋转 + 缩放</span>
            <div class="box-track">
                <div class="box" style="@Box1.Style"></div>
            </div>
        </div>

        <!-- Box2: 拼接动画 — 先移动，等待后再变色 + 缩小 -->
        <div class="box-row">
            <span class="box-label">Box2 · 拼接 · 移动 → 等待 → 变色 + 缩小</span>
            <div class="box-track">
                <div class="box" style="@Box2.Style"></div>
            </div>
        </div>
    </div>

    <div class="demo-tips">
        <p>💡 <code>Snapshot()</code> — 记录显式指定的属性路径（初始状态）</p>
        <p>💡 <code>SnapshotAll()</code> — 自动发现并记录当前对象中所有可动画的属性</p>
        <p>💡 <code>Transition.Exit()</code> — 终止对象持有的动画</p>
    </div>
</div>

<style>
    .demo-root {
        padding: 1.5rem;
        background: #121212;
        min-height: 100vh;
        color: #e0e0e0;
    }
    .demo-title { color: #80cbc4; margin-bottom: .4rem; }
    .demo-desc  { color: #9e9e9e; margin-bottom: 1.2rem; font-size: .95rem; }
    .demo-toolbar { display: flex; gap: .75rem; margin-bottom: 2rem; flex-wrap: wrap; }
    .demo-stage { display: flex; flex-direction: column; gap: 1.5rem; }
    .box-row { display: flex; flex-direction: column; gap: .4rem; }
    .box-label { font-size: .8rem; color: #757575; letter-spacing: .04em; }
    .box-track {
        position: relative;
        height: 100px;
        background: #1e1e1e;
        border-radius: 8px;
        overflow: hidden;
    }
    .box {
        position: absolute;
        top: 10px;
        left: 10px;
        border-radius: 6px;
        transition: none; /* 完全由 VeloxDev 控制，禁用 CSS transition */
    }
    .demo-tips {
        margin-top: 2rem;
        padding: 1rem 1.25rem;
        background: #1e1e1e;
        border-radius: 8px;
        font-size: .88rem;
        line-height: 1.8;
    }
    .demo-tips p { margin: 0; }
    .demo-tips code { color: #80cbc4; }
</style>
