<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 x:Class="VeloxDev.Docs.Views.TranslationSettingsView"
			 Width="320"
			 Height="280">
	<StackPanel Spacing="8" Margin="12">
		<TextBlock Text="Translation Settings" FontWeight="SemiBold" FontSize="14" />

		<Separator Height="1" Margin="0,0,0,4" />

		<TextBlock Text="API Key" FontSize="12" />
		<TextBox x:Name="ApiKeyBox"
				 PlaceholderText="sk-... or DASHSCOPE_API_KEY"
				 PasswordChar="*" />

		<TextBlock Text="Endpoint" FontSize="12" />
		<TextBox x:Name="EndpointBox"
				 PlaceholderText="https://api.openai.com/v1" />

		<TextBlock Text="Model" FontSize="12" />
		<TextBox x:Name="ModelBox"
				 PlaceholderText="gpt-4o / qwen-max" />

		<StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
			<Button x:Name="ApplyButton"
					Content="Apply"
					HorizontalAlignment="Left" />
			<Button x:Name="CancelButton"
					Content="Cancel"
					HorizontalAlignment="Left" />
		</StackPanel>
	</StackPanel>
</UserControl>
