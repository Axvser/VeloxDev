<views:WikiElementViewBase xmlns="https://github.com/avaloniaui"
                           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                           xmlns:views="using:VeloxDev.Docs"
                           xmlns:vm="using:VeloxDev.Docs.ViewModels"
                           mc:Ignorable="d"
                           d:DesignWidth="800"
                           d:DesignHeight="320"
                           x:Class="VeloxDev.Docs.ImageView"
                           x:DataType="vm:ImageProvider">
    <Border x:Name="ChromeBorder"
            Margin="0,0,0,8"
            Padding="8"
            CornerRadius="6">
        <Grid>
            <!-- 浏览模式 -->
            <Grid x:Name="DisplayPanel">
                <Image x:Name="DisplayImage"
                       Source="{Binding Bitmap}"
                       Stretch="Uniform" />
                <!-- 加载中提示 -->
                <Border IsVisible="{Binding IsLoading}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#88000000"
                        CornerRadius="6"
                        Padding="12,6">
                    <TextBlock Text="Loading…"
                               Foreground="White"
                               FontSize="13" />
                </Border>
                <!-- 无图提示 -->
                <Border IsVisible="{Binding !Bitmap}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0.35">
                    <TextBlock Text="No image"
                               FontStyle="Italic"
                               FontSize="13" />
                </Border>
            </Grid>

            <!-- 编辑模式 -->
            <Grid x:Name="EditPanel"
                  IsVisible="False"
                  RowDefinitions="Auto,8,*">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Text="{Binding Source}"
                             Watermark="Raster image path or https://…" />
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="8,0,0,0">
                        <Button Content="Browse"
                                Command="{Binding BrowseCommand}"
                                CommandParameter="{Binding $self}" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="2">
                    <Image x:Name="EditImage"
                           Source="{Binding Bitmap}"
                           Stretch="Uniform" />
                    <Border IsVisible="{Binding IsLoading}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#88000000"
                            CornerRadius="6"
                            Padding="12,6">
                        <TextBlock Text="Loading…"
                                   Foreground="White"
                                   FontSize="13" />
                    </Border>
                    <Thumb x:Name="ResizeThumb"
                           Width="18"
                           Height="18"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</views:WikiElementViewBase>
