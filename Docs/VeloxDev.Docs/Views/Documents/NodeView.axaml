<views:WikiElementViewBase xmlns="https://github.com/avaloniaui"
                           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                           xmlns:views="using:VeloxDev.Docs"
                           xmlns:vm="using:VeloxDev.Docs.ViewModels"
                           mc:Ignorable="d"
                           d:DesignWidth="180"
                           d:DesignHeight="32"
                           x:Class="VeloxDev.Docs.NodeView"
                           x:DataType="vm:NodeProvider">
    <Border x:Name="ChromeBorder"
            Padding="4,2"
            CornerRadius="4"
            BorderBrush="{DynamicResource SystemAccentColor}">
        <Grid>
            <TextBlock x:Name="DisplayPanel"
                       Text="{Binding Title}"
                       VerticalAlignment="Center" />
            <TextBox x:Name="EditPanel"
                     IsVisible="False"
                     Text="{Binding Title}"
                     VerticalAlignment="Center"
                     Padding="4,1" />
        </Grid>
    </Border>
</views:WikiElementViewBase>

