<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:VeloxDev.Docs.ViewModels"
			 xmlns:views="using:VeloxDev.Docs"
			 xmlns:settingsViews="using:VeloxDev.Docs.Views"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="VeloxDev.Docs.DocumentView"
			 x:DataType="vm:DocumentProvider">

	<!-- 固定含 Emoji 按钮的前景色，防止 PointerOver / Pressed 状态切换字体渲染模式导致彩色 Emoji 变灰 -->
	<UserControl.Styles>
		<Style Selector="Button.emoji /template/ ContentPresenter">
			<Setter Property="Foreground" Value="{DynamicResource ButtonForeground}" />
		</Style>
		<Style Selector="Button.emoji:pointerover /template/ ContentPresenter">
			<Setter Property="Foreground" Value="{DynamicResource ButtonForeground}" />
		</Style>
		<Style Selector="Button.emoji:pressed /template/ ContentPresenter">
			<Setter Property="Foreground" Value="{DynamicResource ButtonForeground}" />
		</Style>
		<Style Selector="Button.emoji:disabled /template/ ContentPresenter">
			<Setter Property="Foreground" Value="{DynamicResource ButtonForegroundDisabled}" />
		</Style>
	</UserControl.Styles>

   <!-- 所有模板统一归于此处，Avalonia可自动匹配 -->
	<UserControl.DataTemplates>
		<!-- 目录节点 -->
		<DataTemplate x:DataType="vm:NodeProvider">
            <views:NodeView />
		</DataTemplate>
        <!-- 标题 -->
		<DataTemplate x:DataType="vm:TitleProvider">
          <views:TitleView />
		</DataTemplate>
		<!-- 正文 -->
		<DataTemplate x:DataType="vm:ParagraphProvider">
          <views:ParagraphView />
		</DataTemplate>
		<!-- 副标题 / 引用 -->
		<DataTemplate x:DataType="vm:SubtitleProvider">
          <views:SubtitleView />
		</DataTemplate>
		<!-- 链接 -->
		<DataTemplate x:DataType="vm:LinkProvider">
         <views:LinkView />
		</DataTemplate>
		<!-- 代码块 -->
		<DataTemplate x:DataType="vm:CodeProvider">
         <views:CodeView />
		</DataTemplate>
     <!-- Markdown -->
		<DataTemplate x:DataType="vm:MarkdownProvider">
		 <views:MarkdownView />
		</DataTemplate>
        <!-- 表格 -->
		<DataTemplate x:DataType="vm:TableProvider">
		 <views:TableView />
		</DataTemplate>
        <!-- 图片 -->
		<DataTemplate x:DataType="vm:ImageProvider">
		 <views:ImageView />
		</DataTemplate>
        <!-- 万能空元素 -->
		<DataTemplate x:DataType="vm:EmptyProvider">
		 <views:EmptyView />
		</DataTemplate>
	</UserControl.DataTemplates>

	<!-- 全局布局 -->
	<Grid RowDefinitions="Auto,Auto,*">

		<!-- 顶部工具栏 -->
		<Border Grid.Row="0"
				BorderThickness="0,0,0,1"
				BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
				Padding="8,6">
			<Grid ColumnDefinitions="*,Auto">
				<!-- 模式切换 -->
				<StackPanel Orientation="Horizontal" Spacing="4">
					<Button Content="{Binding EditModeLabel}"
							Command="{Binding ToggleEditModeCommand}"
							IsVisible="{Binding IsEditorSupported}"
							MinWidth="100" />
					<ComboBox ItemsSource="{Binding Languages}"
							  SelectedItem="{Binding SelectedLanguage}"
							  ToolTip.Tip="{Binding LanguageTooltip}"
							  MinWidth="110">
						<ComboBox.ItemTemplate>
							<DataTemplate x:DataType="vm:LanguageOption">
								<TextBlock Text="{Binding DisplayName}" />
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>
					<Separator Width="1" Height="18" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="4,0"
							   IsVisible="{Binding IsEditorSupported}" />
					<!-- 编辑模式下的内容插入工具 (仅 Desktop) -->
					<WrapPanel IsVisible="{Binding IsEditMode}">
						<Button Content="H1" Command="{Binding AddTitleCommand}" CommandParameter="1" Margin="0,0,4,0" ToolTip.Tip="Add Heading 1" />
						<Button Content="H2" Command="{Binding AddTitleCommand}" CommandParameter="2" Margin="0,0,4,0" ToolTip.Tip="Add Heading 2" />
						<Button Content="H3" Command="{Binding AddTitleCommand}" CommandParameter="3" Margin="0,0,4,0" ToolTip.Tip="Add Heading 3" />
						<Button Content="H4" Command="{Binding AddTitleCommand}" CommandParameter="4" Margin="0,0,4,0" ToolTip.Tip="Add Heading 4" />
						<Button Content="P" Command="{Binding AddParagraphCommand}" Margin="0,0,4,0" ToolTip.Tip="Add Paragraph" />
						<Button Classes="emoji" Content="🗨" Command="{Binding AddSubtitleCommand}" Margin="0,0,4,0" ToolTip.Tip="Add Quote / Subtitle" />
						<Button Classes="emoji" Content="🔗" Command="{Binding AddLinkCommand}" Margin="0,0,4,0" ToolTip.Tip="Add Link" />
						<Button Content="&lt;/&gt;" Command="{Binding AddCodeCommand}" Margin="0,0,4,0" ToolTip.Tip="Add Code Block" />
						<Button Content="MD" Command="{Binding AddMarkdownCommand}" Margin="0,0,4,0" ToolTip.Tip="Add Markdown Block" />
						<Button Classes="emoji" Content="📊" Command="{Binding AddTableCommand}" Margin="0,0,4,0" ToolTip.Tip="Add Table" />
						<Button Classes="emoji" Content="🖼" Command="{Binding AddImageCommand}" ToolTip.Tip="Add Image" />
					</WrapPanel>
				</StackPanel>
				<!-- 右侧工具栏 -->
					<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
						<!-- 文件操作 (仅 Desktop) -->
						<Button Content="{Binding SaveLabel}" Command="{Binding SaveCommand}" CommandParameter="{Binding $self}" ToolTip.Tip="{Binding SaveTooltip}" IsVisible="{Binding IsEditorSupported}" />
						<Button Content="{Binding OpenLabel}" Command="{Binding LoadCommand}" CommandParameter="{Binding $self}" ToolTip.Tip="{Binding OpenTooltip}" IsVisible="{Binding IsEditorSupported}" />

						<!-- 翻译目标语言选择 -->
						<ComboBox ItemsSource="{Binding AllLanguages}"
								  SelectedItem="{Binding TranslationTargetLanguage}"
								  IsEnabled="{Binding !IsTranslating}"
								  MinWidth="110"
								  ToolTip.Tip="Target language for translation">
							<ComboBox.ItemTemplate>
								<DataTemplate x:DataType="vm:LanguageOption">
									<TextBlock Text="{Binding DisplayName}" />
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>

						<!-- 翻译当前页 -->
						<Button Classes="emoji" Content="🌐 Translate"
								Command="{Binding TranslateCurrentPageCommand}"
								IsEnabled="{Binding !IsTranslating}"
								ToolTip.Tip="Translate current page via LLM" />

						<!-- 取消翻译 (仅翻译中时显示) -->
						<Button Content="🛑"
								Command="{Binding CancelTranslationCommand}"
								IsVisible="{Binding IsTranslating}"
								ToolTip.Tip="Cancel translation" />

						<!-- 翻译设置按钮：始终可见，用户需先在此配置 API Key -->
						<Button Classes="emoji" x:Name="TranslationSettingsButton"
								Content="⚙"
								ToolTip.Tip="Translation settings (API key, model, endpoint)"
								Click="OnTranslationSettingsClicked" />
					</StackPanel>
			</Grid>
		</Border>

		<!-- 翻译进度条 (仅翻译进行时显示) -->
		<Border Grid.Row="1"
				IsVisible="{Binding IsTranslating}"
				Padding="8,4"
				BorderThickness="0,0,0,1"
				BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
			<Grid ColumnDefinitions="*,Auto">
				<ProgressBar Grid.Column="0"
							 Value="{Binding TranslationProgress}"
							 Minimum="0" Maximum="1"
							 Height="4"
							 VerticalAlignment="Center" />
				<TextBlock Grid.Column="1"
						   Text="{Binding TranslationStatus}"
						   FontSize="10"
						   Opacity="0.7"
						   Margin="8,0,0,0"
						   VerticalAlignment="Center"
						   MaxWidth="300"
						   TextTrimming="CharacterEllipsis" />
			</Grid>
		</Border>

		<!-- 翻译状态文字 (完成/错误，仅非翻译中时显示) -->
		<Border Grid.Row="1"
				IsVisible="{Binding !IsTranslating}"
				Padding="8,2"
				IsHitTestVisible="False">
			<TextBlock Text="{Binding TranslationStatus}"
					   FontSize="10"
					   Opacity="0.6"
					   HorizontalAlignment="Right" />
		</Border>

		<!-- 主体区域 -->
		<Grid Grid.Row="2" ColumnDefinitions="220,4,*">

			<!-- 目录侧边栏 -->
			<Grid Grid.Column="0" RowDefinitions="Auto,*,Auto">
				<TextBlock Grid.Row="0"
						   Text="{Binding NavigationLabel}"
						   Margin="10,8,8,4"
						   Opacity="0.6"
						   FontSize="11"
						   FontFamily="{StaticResource MonoFont}" />
				<TreeView Grid.Row="1"
						  ItemsSource="{Binding Nodes}"
						  SelectedItem="{Binding SelectedNode}"
						  Margin="4,0">
					<TreeView.ItemTemplate>
						<TreeDataTemplate x:DataType="vm:NodeProvider" ItemsSource="{Binding Nodes}">
							<views:NodeView />
						</TreeDataTemplate>
					</TreeView.ItemTemplate>
				</TreeView>
				<!-- 目录操作 (仅编辑模式 + Desktop) -->
				<WrapPanel Grid.Row="2"
						   IsVisible="{Binding IsEditMode}"
						   Margin="6,4,6,6"
						   Orientation="Horizontal">
					<Button Content="{Binding AddPageLabel}" Command="{Binding AddRootCommand}" Margin="0,0,4,4" ToolTip.Tip="{Binding AddPageTooltip}" />
					<Button Content="{Binding AddChildLabel}" Command="{Binding AddChildCommand}" Margin="0,0,4,4" ToolTip.Tip="{Binding AddChildTooltip}" />
				   <Button Classes="emoji" Content="🗑" Command="{Binding RemoveNodeCommand}" Margin="0,0,0,4" ToolTip.Tip="{Binding RemovePageTooltip}" />
				</WrapPanel>
			</Grid>

			<GridSplitter Grid.Column="1" ResizeDirection="Columns" Width="4" />

			<!-- 内容区 -->
			<ScrollViewer x:Name="ContentScrollViewer"
					  Grid.Column="2"
					HorizontalScrollBarVisibility="Disabled"
					  VerticalScrollBarVisibility="Auto"
					  IsScrollChainingEnabled="False">
			   <Border Width="{Binding #ContentScrollViewer.Viewport.Width}"
						Padding="16,12,16,12"
						HorizontalAlignment="Stretch"
						VerticalAlignment="Top">
					<ItemsControl ItemsSource="{Binding Children}"
							  HorizontalAlignment="Stretch"
							  VerticalAlignment="Top" />
				</Border>
			</ScrollViewer>
		</Grid>
	</Grid>
</UserControl>
