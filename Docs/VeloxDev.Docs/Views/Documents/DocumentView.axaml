<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:VeloxDev.Docs.ViewModels"
			 xmlns:views="using:VeloxDev.Docs"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="VeloxDev.Docs.DocumentView"
			 x:DataType="vm:DocumentProvider">

   <!-- 所有模板统一归于此处，Avalonia可自动匹配 -->
	<UserControl.DataTemplates>
		<!-- 目录节点 -->
		<DataTemplate x:DataType="vm:NodeProvider">
            <views:NodeView />
		</DataTemplate>
        <!-- 标题 -->
		<DataTemplate x:DataType="vm:TitleProvider">
          <views:TitleView />
		</DataTemplate>
		<!-- 正文 -->
		<DataTemplate x:DataType="vm:ParagraphProvider">
          <views:ParagraphView />
		</DataTemplate>
		<!-- 副标题 / 引用 -->
		<DataTemplate x:DataType="vm:SubtitleProvider">
          <views:SubtitleView />
		</DataTemplate>
		<!-- 链接 -->
		<DataTemplate x:DataType="vm:LinkProvider">
         <views:LinkView />
		</DataTemplate>
		<!-- 代码块 -->
		<DataTemplate x:DataType="vm:CodeProvider">
         <views:CodeView />
		</DataTemplate>
     <!-- Markdown -->
		<DataTemplate x:DataType="vm:MarkdownProvider">
		 <views:MarkdownView />
		</DataTemplate>
        <!-- 表格 -->
		<DataTemplate x:DataType="vm:TableProvider">
		 <views:TableView />
		</DataTemplate>
        <!-- 图片 -->
		<DataTemplate x:DataType="vm:ImageProvider">
		 <views:ImageView />
		</DataTemplate>
        <!-- 万能空元素 -->
		<DataTemplate x:DataType="vm:EmptyProvider">
		 <views:EmptyView />
		</DataTemplate>
	</UserControl.DataTemplates>

	<!-- 全局布局 -->
	<Grid RowDefinitions="Auto,*">

		<!-- 顶部工具栏 -->
		<Border Grid.Row="0"
				BorderThickness="0,0,0,1"
				BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
				Padding="8,6">
			<Grid ColumnDefinitions="*,Auto">
				<!-- 模式切换 -->
				<StackPanel Orientation="Horizontal" Spacing="4">
					<Button Content="{Binding EditModeLabel}"
							Command="{Binding ToggleEditModeCommand}"
							MinWidth="100" />
					<Separator Width="1" Height="18" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="4,0" />
					<!-- 编辑模式下的内容插入工具 -->
					<WrapPanel IsVisible="{Binding IsEditMode}">
						<Button Content="H1" Command="{Binding AddTitleCommand}" CommandParameter="1" Margin="0,0,4,0" ToolTip.Tip="Add Heading 1" />
						<Button Content="H2" Command="{Binding AddTitleCommand}" CommandParameter="2" Margin="0,0,4,0" ToolTip.Tip="Add Heading 2" />
						<Button Content="H3" Command="{Binding AddTitleCommand}" CommandParameter="3" Margin="0,0,4,0" ToolTip.Tip="Add Heading 3" />
						<Button Content="H4" Command="{Binding AddTitleCommand}" CommandParameter="4" Margin="0,0,4,0" ToolTip.Tip="Add Heading 4" />
						<Button Content="P" Command="{Binding AddParagraphCommand}" Margin="0,0,4,0" ToolTip.Tip="Add Paragraph" />
						<Button Content="🗨" Command="{Binding AddSubtitleCommand}" Margin="0,0,4,0" ToolTip.Tip="Add Quote / Subtitle" />
						<Button Content="🔗" Command="{Binding AddLinkCommand}" Margin="0,0,4,0" ToolTip.Tip="Add Link" />
						<Button Content="&lt;/&gt;" Command="{Binding AddCodeCommand}" Margin="0,0,4,0" ToolTip.Tip="Add Code Block" />
                        <Button Content="MD" Command="{Binding AddMarkdownCommand}" Margin="0,0,4,0" ToolTip.Tip="Add Markdown Block" />
						<Button Content="📊" Command="{Binding AddTableCommand}" Margin="0,0,4,0" ToolTip.Tip="Add Table" />
						<Button Content="🖼" Command="{Binding AddImageCommand}" ToolTip.Tip="Add Image" />
					</WrapPanel>
				</StackPanel>
				<!-- 文件操作 -->
				<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
					<Button Content="💾 Save" Command="{Binding SaveCommand}" CommandParameter="{Binding $self}" ToolTip.Tip="Save to JSON" />
					<Button Content="📂 Open" Command="{Binding LoadCommand}" CommandParameter="{Binding $self}" ToolTip.Tip="Open JSON" />
				</StackPanel>
			</Grid>
		</Border>

		<!-- 主体区域 -->
		<Grid Grid.Row="1" ColumnDefinitions="220,4,*">

			<!-- 目录侧边栏 -->
			<Grid Grid.Column="0" RowDefinitions="Auto,*,Auto">
				<TextBlock Grid.Row="0"
						   Text="Navigation"
						   Margin="10,8,8,4"
						   FontWeight="SemiBold"
						   Opacity="0.6"
						   FontSize="11" />
				<TreeView Grid.Row="1"
						  ItemsSource="{Binding Nodes}"
						  SelectedItem="{Binding SelectedNode}"
						  Margin="4,0">
					<TreeView.ItemTemplate>
						<TreeDataTemplate x:DataType="vm:NodeProvider" ItemsSource="{Binding Nodes}">
							<views:NodeView />
						</TreeDataTemplate>
					</TreeView.ItemTemplate>
				</TreeView>
				<!-- 目录操作 (仅编辑模式) -->
				<WrapPanel Grid.Row="2"
						   IsVisible="{Binding IsEditMode}"
						   Margin="6,4,6,6"
						   Orientation="Horizontal">
					<Button Content="+ Page" Command="{Binding AddRootCommand}" Margin="0,0,4,4" ToolTip.Tip="Add root page" />
					<Button Content="+ Child" Command="{Binding AddChildCommand}" Margin="0,0,4,4" ToolTip.Tip="Add child page" />
                   <Button Content="🗑" Command="{Binding RemoveNodeCommand}" Margin="0,0,0,4" ToolTip.Tip="Remove selected page" />
				</WrapPanel>
			</Grid>

			<GridSplitter Grid.Column="1" ResizeDirection="Columns" Width="4" />

			<!-- 内容区 -->
			<ScrollViewer x:Name="ContentScrollViewer"
					  Grid.Column="2"
					HorizontalScrollBarVisibility="Disabled"
					  VerticalScrollBarVisibility="Auto"
					  IsScrollChainingEnabled="False">
			   <Border Width="{Binding #ContentScrollViewer.Viewport.Width}"
						Padding="16,12,16,12"
						HorizontalAlignment="Stretch"
						VerticalAlignment="Top">
					<ItemsControl ItemsSource="{Binding Children}"
							  HorizontalAlignment="Stretch"
							  VerticalAlignment="Top" />
				</Border>
			</ScrollViewer>
		</Grid>
	</Grid>
</UserControl>
