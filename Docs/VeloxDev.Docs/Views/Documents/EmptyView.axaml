<views:WikiElementViewBase xmlns="https://github.com/avaloniaui"
						   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
						   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
						   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
						   xmlns:views="using:VeloxDev.Docs"
						   xmlns:vm="using:VeloxDev.Docs.ViewModels"
						   mc:Ignorable="d"
						   d:DesignWidth="800"
						   d:DesignHeight="56"
						   x:Class="VeloxDev.Docs.EmptyView"
						   x:DataType="vm:EmptyProvider">
	<Border x:Name="ChromeBorder"
			Margin="0,0,0,8"
			Padding="8"
			CornerRadius="6"
			BorderBrush="{DynamicResource SystemAccentColor}">
		<Grid>
			<TextBlock x:Name="DisplayPanel"
					   Text="Empty element — right-click in Edit Mode to convert or remove"
					   Opacity="0.4"
					   FontStyle="Italic"
					   FontSize="12" />
			<TextBlock x:Name="EditPanel"
					   IsVisible="False"
					   Text="Use context menu to convert or remove this element."
					   Opacity="0.65"
					   FontSize="12" />
		</Grid>
	</Border>
</views:WikiElementViewBase>

