<views:WikiElementViewBase xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:views="using:VeloxDev.Docs"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="VeloxDev.Docs.CodeView"
			 xmlns:vm="using:VeloxDev.Docs.ViewModels"
			 x:DataType="vm:CodeProvider">
   <Border x:Name="ChromeBorder"
			Margin="0,0,0,8"
			Padding="8"
			CornerRadius="6"
          HorizontalAlignment="Stretch"
			BorderBrush="{DynamicResource SystemAccentColor}">
      <Grid x:Name="RootPanel" HorizontalAlignment="Stretch">
		  <Grid x:Name="DisplayPanel" RowDefinitions="Auto,4,*" HorizontalAlignment="Stretch">
				<Grid ColumnDefinitions="*,Auto">
					<TextBlock Text="{Binding Language}" Opacity="0.6" FontSize="12" VerticalAlignment="Center" />
					<Button Grid.Column="1" Content="Copy"
							Command="{Binding CopyCommand}"
							CommandParameter="{Binding $self}"
							Padding="8,2" />
				</Grid>
             <ScrollViewer x:Name="DisplayScrollViewer" Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" IsScrollChainingEnabled="False" HorizontalAlignment="Stretch">
					<SelectableTextBlock Inlines="{Binding Inlines}"
									 LineHeight="18"
                                     FontFamily="Cascadia Code,Cascadia Mono,Sarasa Mono SC,Microsoft YaHei UI,Segoe UI,monospace"
									 FontSize="13" />
				</ScrollViewer>
			</Grid>

           <Grid x:Name="EditPanel" IsVisible="False" RowDefinitions="Auto,8,*" HorizontalAlignment="Stretch">
				<Grid ColumnDefinitions="Auto,8,*,Auto">
					<TextBlock Text="Language" VerticalAlignment="Center" Opacity="0.6" FontSize="12" />
                 <ComboBox Grid.Column="2"
							  ItemsSource="{Binding Languages}"
							  SelectedItem="{Binding Language}"
							  MinWidth="140" />
					<Button Grid.Column="3" Content="Copy"
							Command="{Binding CopyCommand}"
							CommandParameter="{Binding $self}"
							Margin="8,0,0,0" />
				</Grid>
             <ScrollViewer x:Name="EditScrollViewer" Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" IsScrollChainingEnabled="False" HorizontalAlignment="Stretch">
					<TextBox Text="{Binding Code}"
							 AcceptsReturn="True"
							 TextWrapping="NoWrap"
                             FontFamily="Cascadia Code,Cascadia Mono,Sarasa Mono SC,Microsoft YaHei UI,Segoe UI,monospace"
							 FontSize="13"
                             MinHeight="96"
							 PlaceholderText="Code" />
				</ScrollViewer>
			</Grid>
		</Grid>
	</Border>
</views:WikiElementViewBase>
