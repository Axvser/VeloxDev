<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VeloxDev.Docs.ViewModels"
             x:Class="VeloxDev.Docs.Views.TranslatorSettingsView"
             x:DataType="vm:TranslatorSettingsViewModel"
             Width="420">
    <Border Padding="16" CornerRadius="6">
        <StackPanel Spacing="10">
            <TextBlock Text="Translation Settings" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4" />
            <StackPanel Spacing="4">
                <TextBlock Text="DashScope API Key" Opacity="0.7" FontSize="11" />
                <TextBox Text="{Binding ApiKey}" PasswordChar="*" PlaceholderText="sk-xxxxxxxxxxxxxxxxxxxxxxxx" FontFamily="{StaticResource MonoFont}" />
                <TextBlock FontSize="10" Opacity="0.5" TextWrapping="Wrap" Text="Obtain from https://bailian.console.aliyun.com or set DASHSCOPE_API_KEY env var." />
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="Model" Opacity="0.7" FontSize="11" />
                <TextBox Text="{Binding Model}" PlaceholderText="qwen-plus" />
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="Endpoint" Opacity="0.7" FontSize="11" />
                <TextBox Text="{Binding Endpoint}" PlaceholderText="https://dashscope.aliyuncs.com/compatible-mode/v1" />
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="Translation Mode" Opacity="0.7" FontSize="11" />
                <ComboBox ItemsSource="{Binding TranslationModes}" SelectedItem="{Binding SelectedMode}" HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:WikiTranslationModeOption">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="Medium" />
                                <TextBlock Text="{Binding Description}" Opacity="0.6" FontSize="10" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="Max Concurrency" Opacity="0.7" FontSize="11" />
                <Grid ColumnDefinitions="Auto,*">
                    <NumericUpDown Grid.Column="0" Minimum="1" Maximum="32" Increment="1"
                                   Value="{Binding MaxConcurrency}" Width="140" />
                    <TextBlock Grid.Column="1" Text="(1 = sequential, 8-16 = fast)"
                               Opacity="0.5" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0" />
                </Grid>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,4,0,0">
                <Button Content="Cancel" Click="OnCancelClicked" />
                <Button Content="Apply" Click="OnApplyClicked" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
