<?xml version="1.0" encoding="utf-8" ?>
<!-- Customize the content, but keep PART_* names synchronized with WorkflowSlotLayoutBehavior. -->
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:TemplateNamespace"
             xmlns:behaviors="clr-namespace:VeloxDev.WorkflowSystem.AttachedBehaviors;assembly=VeloxDev.MAUI"
             x:Class="TemplateNamespace.TemplateClass"
             behaviors:WorkflowSlotLayoutBehavior.IsEnabled="True" behaviors:WorkflowSlotLayoutBehavior.SlotNames="PART_InputSlot" behaviors:WorkflowSlotLayoutBehavior.SlotEnumeratorNames="PART_OutputSlots" behaviors:WorkflowSlotLayoutBehavior.CoordinateHostName="PART_Canvas">
    <Grid RowDefinitions="36,*">
        <Border Grid.RowSpan="2"
                Stroke="TemplateNodeBorderBrush"
                StrokeThickness="TemplateNodeBorderThickness"
                StrokeShape="RoundRectangle TemplateNodeCornerRadius"
                BackgroundColor="TemplateNodeBackground" />

        <Grid behaviors:WorkflowNodeDragBehavior.CoordinateHostName="PART_Canvas" behaviors:WorkflowNodeDragBehavior.IsEnabled="True"
              Grid.Row="0"
              Margin="12,0">
            <Label Text="{Binding Name}"
                   TextColor="TemplateNodeForeground"
                   FontAttributes="Bold"
                   VerticalTextAlignment="Center" />
        </Grid>

        <Grid Grid.Row="1" ZIndex="6" InputTransparent="True" CascadeInputTransparent="False">
            <controls:SlotView x:Name="PART_InputSlot" BindingContext="{Binding InputSlot}" SlotState="{Binding State}"
                                       WidthRequest="18"
                                       HeightRequest="18"
                                       HorizontalOptions="Start"
                                       VerticalOptions="Center"
                                       Margin="2,0,0,0" />
        </Grid>

        <VerticalStackLayout x:Name="PART_OutputSlots" BindableLayout.ItemsSource="{Binding OutputSlots.Items}"
                             Grid.Row="1"
                             Margin="12,6"
                             Spacing="6"
                             VerticalOptions="Center">
            <BindableLayout.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="{Binding Name}"
                               TextColor="TemplateNodeForeground"
                               HorizontalTextAlignment="End"
                               VerticalTextAlignment="Center"
                               Margin="0,0,10,0" />
                        <controls:SlotView BindingContext="{Binding Slot}" SlotState="{Binding Slot.State}"
                                                   Grid.Column="1"
                                                   WidthRequest="14"
                                                   HeightRequest="14"
                                                   Margin="0" />
                    </Grid>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </VerticalStackLayout>
    </Grid>
</ContentView>
