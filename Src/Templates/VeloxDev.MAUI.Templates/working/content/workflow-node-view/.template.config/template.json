{
  "$schema": "http://json.schemastore.org/template",
  "author": "Axvser",
  "classifications": [
    "VeloxDev",
    "Workflow",
    "MAUI",
    "XAML",
    "Node"
  ],
  "identity": "VeloxDev.MAUI.WorkflowNodeView",
  "name": "VeloxDev MAUI Workflow Node View",
  "description": "A minimal .NET MAUI view for a VeloxDev workflow node component.",
  "shortName": "maui-v-node",
  "sourceName": "TemplateClass",
  "defaultName": "NodeView",
  "preferNameDirectory": false,
  "tags": {
    "language": "C#",
    "type": "item"
  },
  "symbols": {
    "namespace": {
      "type": "parameter",
      "datatype": "text",
      "description": "Namespace for the generated node view.",
      "defaultValue": "MyApp.Views",
      "replaces": "TemplateNamespace"
    },
    "nodeBackground": {
      "type": "parameter",
      "datatype": "text",
      "description": "Node background color.",
      "defaultValue": "#DDFFFFFF",
      "replaces": "TemplateNodeBackground"
    },
    "nodeForeground": {
      "type": "parameter",
      "datatype": "text",
      "description": "Node foreground color.",
      "defaultValue": "#DD1E1E1E",
      "replaces": "TemplateNodeForeground"
    },
    "nodeBorderBrush": {
      "type": "parameter",
      "datatype": "text",
      "description": "Node border color.",
      "defaultValue": "#331E1E1E",
      "replaces": "TemplateNodeBorderBrush"
    },
    "nodeBorderThickness": {
      "type": "parameter",
      "datatype": "text",
      "description": "Node border thickness.",
      "defaultValue": "1",
      "replaces": "TemplateNodeBorderThickness"
    },
    "nodeCornerRadius": {
      "type": "parameter",
      "datatype": "text",
      "description": "Node corner radius.",
      "defaultValue": "6",
      "replaces": "TemplateNodeCornerRadius"
    }
  },
  "primaryOutputs": [
    {
      "path": "TemplateClass.xaml"
    },
    {
      "path": "TemplateClass.xaml.cs"
    }
  ]
}
