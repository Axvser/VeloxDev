{
  "$schema": "http://json.schemastore.org/template",
  "author": "Axvser",
  "classifications": [
    "VeloxDev",
    "Workflow",
    "MAUI",
    "XAML",
    "Link"
  ],
  "identity": "VeloxDev.MAUI.WorkflowLinkView",
  "name": "VeloxDev MAUI Workflow Link View",
  "description": "A minimal .NET MAUI view for a VeloxDev workflow link component.",
  "shortName": "maui-v-link",
  "sourceName": "TemplateClass",
  "defaultName": "LinkView",
  "preferNameDirectory": false,
  "tags": {
    "language": "C#",
    "type": "item"
  },
  "symbols": {
    "namespace": {
      "type": "parameter",
      "datatype": "text",
      "description": "Namespace for the generated link view.",
      "defaultValue": "MyApp.Views",
      "replaces": "TemplateNamespace"
    },
    "linkColor": {
      "type": "parameter",
      "datatype": "text",
      "description": "Link line color.",
      "defaultValue": "#DDFFFFFF",
      "replaces": "TemplateLinkColor"
    },
    "linkThickness": {
      "type": "parameter",
      "datatype": "text",
      "description": "Link line thickness.",
      "defaultValue": "2",
      "replaces": "TemplateLinkThickness"
    }
  },
  "primaryOutputs": [
    {
      "path": "TemplateClass.xaml"
    },
    {
      "path": "TemplateClass.xaml.cs"
    }
  ]
}
