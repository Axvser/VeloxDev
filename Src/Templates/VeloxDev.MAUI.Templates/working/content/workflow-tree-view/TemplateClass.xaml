<?xml version="1.0" encoding="utf-8" ?>
<!-- VeloxDev customization: Generate the Node, Slot, Link, selector, and grid-decorator templates, then update the local type names below if you renamed them. -->
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TemplateNamespace"
             xmlns:behaviors="clr-namespace:VeloxDev.WorkflowSystem.AttachedBehaviors;assembly=VeloxDev.MAUI"
             x:Class="TemplateNamespace.TemplateClass"
             behaviors:WorkflowSurfaceBehavior.IsEnabled="True"
             behaviors:WorkflowSurfaceBehavior.ScrollViewerName="PART_ScrollViewer"
             behaviors:WorkflowSurfaceBehavior.CanvasName="PART_Canvas"
             behaviors:WorkflowSurfaceBehavior.GridDecoratorName="PART_GridDecorator"
             behaviors:WorkflowSurfaceBehavior.PointerPressSourceName="PART_SurfaceBorder">
    <ContentView.Resources>
        <DataTemplate x:Key="NodeTemplate">
            <local:WorkflowNodeView WidthRequest="{Binding Size.Width}"
                                    HeightRequest="{Binding Size.Height}" />
        </DataTemplate>
        <DataTemplate x:Key="LinkTemplate">
            <local:WorkflowLinkView StartLeft="{Binding Sender.Anchor.Horizontal}"
                                    StartTop="{Binding Sender.Anchor.Vertical}"
                                    EndLeft="{Binding Receiver.Anchor.Horizontal}"
                                    EndTop="{Binding Receiver.Anchor.Vertical}"
                                    ContentOffsetX="{Binding Source={x:Reference PART_Canvas}, Path=TranslationX}"
                                    ContentOffsetY="{Binding Source={x:Reference PART_Canvas}, Path=TranslationY}"
                                    CanRender="{Binding IsVisible}"
                                    WidthRequest="{Binding Source={x:Reference PART_Canvas}, Path=WidthRequest}"
                                    HeightRequest="{Binding Source={x:Reference PART_Canvas}, Path=HeightRequest}" />
        </DataTemplate>
        <local:WorkflowTemplateSelector x:Key="WorkflowTemplateSelector"
                                        NodeTemplate="{StaticResource NodeTemplate}"
                                        LinkTemplate="{StaticResource LinkTemplate}" />
    </ContentView.Resources>

    <Border x:Name="PART_SurfaceBorder"
            Stroke="#33FFFFFF"
            StrokeThickness="1"
            BackgroundColor="#1E1E1E">
        <local:WorkflowGridDecorator x:Name="PART_GridDecorator">
            <ScrollView x:Name="PART_ScrollViewer" Orientation="Both">
                <AbsoluteLayout x:Name="PART_Canvas"
                                WidthRequest="{Binding Layout.ActualSize.Width}"
                                HeightRequest="{Binding Layout.ActualSize.Height}">
                    <!-- Keep this virtual link so connection dragging has immediate visual feedback. -->
                    <local:WorkflowLinkView BindingContext="{Binding VirtualLink}"
                                            StartLeft="{Binding Sender.Anchor.Horizontal}"
                                            StartTop="{Binding Sender.Anchor.Vertical}"
                                            EndLeft="{Binding Receiver.Anchor.Horizontal}"
                                            EndTop="{Binding Receiver.Anchor.Vertical}"
                                            ContentOffsetX="{Binding Source={x:Reference PART_Canvas}, Path=TranslationX}"
                                            ContentOffsetY="{Binding Source={x:Reference PART_Canvas}, Path=TranslationY}"
                                            CanRender="{Binding IsVisible}"
                                            IsVirtual="True"
                                            LineColor="White"
                                            WidthRequest="{Binding Source={x:Reference PART_Canvas}, Path=WidthRequest}"
                                            HeightRequest="{Binding Source={x:Reference PART_Canvas}, Path=HeightRequest}"
                                            ZIndex="-1" />
                </AbsoluteLayout>
            </ScrollView>
        </local:WorkflowGridDecorator>
    </Border>
</ContentView>
