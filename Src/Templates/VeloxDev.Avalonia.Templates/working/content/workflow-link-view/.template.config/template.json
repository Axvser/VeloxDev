{
  "$schema": "http://json.schemastore.org/template",
  "author": "Axvser",
  "classifications": [
    "VeloxDev",
    "Workflow",
    "Avalonia",
    "XAML",
    "Link"
  ],
  "identity": "VeloxDev.Avalonia.WorkflowLinkView",
  "name": "VeloxDev Avalonia Workflow Link View",
  "description": "A minimal Avalonia view for a VeloxDev workflow link component.",
  "shortName": "ava-v-link",
  "sourceName": "TemplateClass",
  "defaultName": "WorkflowLinkView",
  "preferNameDirectory": false,
  "tags": {
    "language": "C#",
    "type": "item"
  },
  "symbols": {
    "namespace": {
      "type": "parameter",
      "datatype": "text",
      "description": "Namespace for the generated link view.",
      "defaultValue": "MyApp.Views.Workflow",
      "replaces": "TemplateNamespace"
    }
  },
  "primaryOutputs": [
    {
      "path": "TemplateClass.axaml"
    },
    {
      "path": "TemplateClass.axaml.cs"
    }
  ]
}
