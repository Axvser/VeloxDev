{
  "$schema": "http://json.schemastore.org/template",
  "author": "Axvser",
  "classifications": [ "VeloxDev", "Workflow", "Avalonia", "Code" ],
  "identity": "VeloxDev.Avalonia.WorkflowTemplateSelector",
  "name": "VeloxDev Avalonia Workflow Template Selector",
  "description": "An Avalonia IDataTemplate selector for VeloxDev node, slot, link, and tree view models.",
  "shortName": "ava-v-selector",
  "sourceName": "TemplateClass",
  "defaultName": "WorkflowTemplateSelector",
  "preferNameDirectory": false,
  "tags": {
    "language": "C#",
    "type": "item"
  },
  "symbols": {
    "namespace": {
      "type": "parameter",
      "datatype": "text",
      "description": "Namespace for the generated selector.",
      "defaultValue": "MyApp.Views",
      "replaces": "TemplateNamespace"
    }
  },
  "primaryOutputs": [
    { "path": "TemplateClass.cs" }
  ]
}
