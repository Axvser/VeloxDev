{
  "$schema": "http://json.schemastore.org/template",
  "author": "Axvser",
  "classifications": [
    "VeloxDev",
    "Workflow",
    "Avalonia",
    "XAML",
    "Tree"
  ],
  "identity": "VeloxDev.Avalonia.WorkflowTreeView",
  "name": "VeloxDev Avalonia Workflow Tree View",
  "description": "A minimal Avalonia view for a VeloxDev workflow tree component.",
  "shortName": "ava-v-tree",
  "sourceName": "TemplateClass",
  "defaultName": "TreeView",
  "preferNameDirectory": false,
  "tags": {
    "language": "C#",
    "type": "item"
  },
  "symbols": {
    "namespace": {
      "type": "parameter",
      "datatype": "text",
      "description": "Namespace for the generated tree view.",
      "defaultValue": "MyApp.Views",
      "replaces": "TemplateNamespace"
    },
    "surfaceBackground": {
      "type": "parameter",
      "datatype": "text",
      "description": "Workflow surface background color.",
      "defaultValue": "#1E1E1E",
      "replaces": "TemplateSurfaceBackground"
    },
    "surfaceBorderBrush": {
      "type": "parameter",
      "datatype": "text",
      "description": "Workflow surface border color.",
      "defaultValue": "#33FFFFFF",
      "replaces": "TemplateSurfaceBorderBrush"
    },
    "surfaceBorderThickness": {
      "type": "parameter",
      "datatype": "text",
      "description": "Workflow surface border thickness.",
      "defaultValue": "1",
      "replaces": "TemplateSurfaceBorderThickness"
    },
    "surfaceCornerRadius": {
      "type": "parameter",
      "datatype": "text",
      "description": "Workflow surface corner radius.",
      "defaultValue": "3",
      "replaces": "TemplateSurfaceCornerRadius"
    }
  },
  "primaryOutputs": [
    {
      "path": "TemplateClass.axaml"
    },
    {
      "path": "TemplateClass.axaml.cs"
    }
  ]
}
